# Strait — Unified Environment Variables
# Managed via Doppler (project: strait, configs: dev / stg / prd)
#
# For local development, run:
#   doppler setup          (select project: strait, config: dev)
#   doppler run -- <cmd>   (injects all env vars into your process)
#
# Or generate a local .env file:
#   doppler secrets download --no-file --format env > .env

# ──────────────────────────────────────────────
# Core Configuration
# ──────────────────────────────────────────────
STRAIT_API_URL=http://localhost:8080
STRAIT_EDITION=community
DATABASE_URL=postgres://strait:strait@localhost:5432/strait?sslmode=disable
REDIS_URL=redis://localhost:6379
MODE=all
PORT=8080
LOG_LEVEL=info
LOG_FORMAT=text
# INTERNAL_SECRET: min 16 chars. Used for service-to-service auth.
# Generate with: openssl rand -hex 16
INTERNAL_SECRET=local-dev-internal-secret-change-me
# JWT_SIGNING_KEY: min 32 chars. Used for SDK run tokens and SSE.
# Generate with: openssl rand -hex 32
JWT_SIGNING_KEY=local-dev-jwt-signing-key-change-me-32chars

# ──────────────────────────────────────────────
# Worker Configuration
# ──────────────────────────────────────────────
WORKER_CONCURRENCY=25
WORKER_DRAIN_TIMEOUT=30s
WORKER_QUEUE_SIZE=0
WORKER_PARTITIONS=
WORKER_PARTITION_WEIGHTS=

# ──────────────────────────────────────────────
# Scheduler Configuration
# ──────────────────────────────────────────────
HEARTBEAT_INTERVAL=10s
REAPER_INTERVAL=30s
STALE_THRESHOLD=60s
POLLER_INTERVAL=5s
REAPER_DELETE_BATCH_SIZE=100
INDEX_MAINTENANCE_INTERVAL=24h
LOG_DRAIN_WORKER_INTERVAL=60s
DEBOUNCE_POLLER_INTERVAL=1s
NOTIFY_DELIVERY_MAX_ATTEMPTS=5
NOTIFY_RETRY_BASE_DELAY=30s
NOTIFY_RETRY_MAX_DELAY=15m
NOTIFY_DIGEST_MAX_ITEMS=50
NOTIFY_DIGEST_MAX_TITLE_CHARS=120
NOTIFY_ESCALATION_TIERS=3
NOTIFY_ESCALATION_MIN_INTERVAL=10m
NOTIFY_SUBSCRIBER_TOKEN_ISSUER=strait-notify
NOTIFY_SUBSCRIBER_TOKEN_AUDIENCE=strait-notify-subscriber

# ──────────────────────────────────────────────
# Database Pool Configuration
# ──────────────────────────────────────────────
# DB_MAX_CONNS should be >= WORKER_CONCURRENCY to avoid pool exhaustion.
# With N replicas, total connections = DB_MAX_CONNS * N.
# Ensure your PostgreSQL max_connections exceeds this sum.
DB_MAX_CONNS=50
DB_MIN_CONNS=10
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m
DB_PGBOUNCER_MODE=false
DB_STATEMENT_TIMEOUT=30s

# ──────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
DEFAULT_API_KEY_RATE_LIMIT=1000
DEFAULT_API_KEY_RATE_WINDOW_SECS=60
TRIGGER_RATE_LIMIT_REQUESTS=10
TRIGGER_RATE_LIMIT_WINDOW=1m

# ──────────────────────────────────────────────
# Request Configuration
# ──────────────────────────────────────────────
REQUEST_TIMEOUT=30s
MAX_REQUEST_BODY_SIZE=1048576
MAX_BULK_TRIGGER_ITEMS=500

# ──────────────────────────────────────────────
# Job Defaults
# ──────────────────────────────────────────────
DEFAULT_JOB_MAX_ATTEMPTS=3
DEFAULT_JOB_TIMEOUT_SECS=300
DEFAULT_JOB_MAX_CONCURRENCY=0
DEFAULT_RUN_TTL_SECS=0
MAX_RESULT_SIZE=1048576
MAX_SNOOZE_COUNT=50

# ──────────────────────────────────────────────
# Executor Configuration
# ──────────────────────────────────────────────
EXECUTOR_HTTP_TIMEOUT=5m
EXECUTOR_IDLE_CONN_TIMEOUT=90s
DEQUEUE_STRATEGY=priority
MAX_DEQUEUE_BATCH_SIZE=0
JOB_CACHE_TTL=5m
BATCH_FLUSH_INTERVAL=1s
MEMORY_PRESSURE_THRESHOLD_PCT=0

# ──────────────────────────────────────────────
# Sequin CDC Configuration
# ──────────────────────────────────────────────
SEQUIN_ADMIN_PASSWORD=
SEQUIN_API_TOKEN=
SEQUIN_BASE_URL=
SEQUIN_CONSUMER_NAME=
SEQUIN_BATCH_SIZE=10
SEQUIN_WAIT_TIME_MS=5000
CDC_BATCH_SIZE=10
CDC_WAIT_TIME_MS=5000

# ──────────────────────────────────────────────
# CORS Configuration
# ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

# ──────────────────────────────────────────────
# Retention Configuration
# ──────────────────────────────────────────────
RUN_RETENTION_SHORT=720h
RUN_RETENTION_LONG=2160h
WORKFLOW_RUN_RETENTION_DAYS=30
WORKFLOW_RETENTION=720h
EVENT_TRIGGER_RETENTION_DAYS=
EVENT_TRIGGER_RETENTION=168h

# ──────────────────────────────────────────────
# Redis Sentinel Configuration
# ──────────────────────────────────────────────
REDIS_SENTINEL_MASTER=
REDIS_SENTINEL_ADDRS=

# ──────────────────────────────────────────────
# Workflow Configuration
# ──────────────────────────────────────────────
MAX_WORKFLOW_NESTING_DEPTH=10
WF_STALL_THRESHOLD=15m
WF_STALL_ACTION=log_only
WF_MAX_STEP_CAP=100
WF_STEP_CONCURRENCY_LIMIT=0
DEPENDENCY_STATUS_CACHE_TTL=5s

# ──────────────────────────────────────────────
# SSE Configuration
# ──────────────────────────────────────────────
SSE_KEEPALIVE_INTERVAL=15s

# ──────────────────────────────────────────────
# Webhook Configuration
# ──────────────────────────────────────────────
WEBHOOK_TIMEOUT=10s
WEBHOOK_IDLE_CONN_TIMEOUT=60s
WEBHOOK_DISPATCH_TIMEOUT=15s
WEBHOOK_MAX_PAYLOAD_BYTES=1048576
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_CONCURRENCY=50
WEBHOOK_BATCH_ENABLED=false
WEBHOOK_MAX_BATCH_SIZE=50
WEBHOOK_MAX_IDLE_CONNS=100
WEBHOOK_MAX_IDLE_CONNS_PER_HOST=50
WEBHOOK_REQUIRE_TLS=false

# ──────────────────────────────────────────────
# Managed Execution
# ──────────────────────────────────────────────
# COMPUTE_RUNTIME: "k8s" (production), "docker" (local dev), "none" (HTTP mode only)
# COMPUTE_FALLBACK_PROVIDER: optional fallback runtime (e.g., "docker" as fallback for "k8s").
COMPUTE_RUNTIME=docker
COMPUTE_FALLBACK_PROVIDER=
DEFAULT_REGION=iad
# EXTERNAL_API_URL is the URL job containers use to call back to the Strait API.
# For local Docker managed mode, use http://host.docker.internal:8080 so containers
# inside Docker can reach the Strait server running on the host.
EXTERNAL_API_URL=http://host.docker.internal:8080
MAX_CONCURRENT_MACHINES=10
WARM_POOL_ENABLED=false
WARM_POOL_MAX_PER_JOB=3
WARM_POOL_TTL=5m
DISABLE_MACHINE_POOL_REUSE=true
# ALLOWED_IMAGE_REGISTRIES restricts which registries managed jobs can pull from.
# For local dev, allow Docker Hub and GitHub Container Registry.
ALLOWED_IMAGE_REGISTRIES=docker.io,ghcr.io
REQUIRE_IMAGE_DIGEST=false
ENFORCE_REGION_GATING=false

# ──────────────────────────────────────────────
# Kubernetes Runtime (when COMPUTE_RUNTIME=k8s)
# ──────────────────────────────────────────────
# K8S_KUBECONFIG: path to kubeconfig file. Leave empty for in-cluster auth.
# For local kind dev: K8S_KUBECONFIG=~/.kube/config
# For Hetzner production: K8S_KUBECONFIG=./infra/kubeconfig
K8S_KUBECONFIG=
K8S_NAMESPACE=default
K8S_PRIORITY_CLASS=strait-job

# ──────────────────────────────────────────────
# Hetzner Infrastructure (for infra/ Terraform)
# ──────────────────────────────────────────────
# These are used by infra/scripts/setup.sh when running via Doppler.
# Add to Doppler: doppler secrets set HCLOUD_TOKEN --project strait --config dev
HCLOUD_TOKEN=
SSH_KEY_PATH=~/.ssh/id_ed25519.pub
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519
HETZNER_LOCATION=fsn1
HETZNER_GENERAL_COUNT=1
HETZNER_PERF_COUNT=1
HETZNER_HEAVY_COUNT=0

# ──────────────────────────────────────────────
# Security & Access Control
# ──────────────────────────────────────────────
ALLOW_PRIVATE_ENDPOINTS=true
BILLING_ENFORCEMENT_ENABLED=false
DISABLE_EMAIL_VERIFICATION=false
DISABLE_STRIPE_BILLING=false
PERMISSION_CACHE_TTL=

# ──────────────────────────────────────────────
# Encryption Configuration
# ──────────────────────────────────────────────
ENCRYPTION_KEY=
ENCRYPTION_KEY_OLD=
# SECRET_ENCRYPTION_KEY encrypts job secrets at rest. Required for the
# /v1/secrets/ endpoints. Falls back to ENCRYPTION_KEY if unset. Generate
# a random 32+ character string, e.g.: openssl rand -hex 32
SECRET_ENCRYPTION_KEY=

# ──────────────────────────────────────────────
# OIDC / OAuth Configuration
# Go API uses OIDC_PUBLIC_KEY_PEM to verify JWTs.
# TanStack app uses OIDC_PRIVATE_KEY_PEM to sign JWTs.
# Both share the same OIDC_ISSUER and OIDC_AUDIENCE values.
# ──────────────────────────────────────────────
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_PUBLIC_KEY_PEM=
OIDC_PRIVATE_KEY_PEM=

# ──────────────────────────────────────────────
# Database Migrations
# ──────────────────────────────────────────────
MIGRATION_MODE=auto
MIGRATION_LOCK_TIMEOUT=30s
DEBUG_STATSVIZ=false

# ──────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────
# Logs: app sends OTLP to the OTel Collector, which routes to Grafana Cloud Loki.
# Traces: app sends OTLP to the OTel Collector, which routes to ClickHouse.
# Metrics: /metrics endpoint scraped by OTel Collector, forwarded to Grafana Cloud.
# Errors: Sentry SDK captures error-level logs with stack traces.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTLP_METRIC_ENDPOINT=
OTLP_METRIC_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
PYROSCOPE_ENDPOINT=
PYROSCOPE_AUTH_TOKEN=

# ──────────────────────────────────────────────
# Grafana Cloud
# ──────────────────────────────────────────────
GRAFANA_URL=
GRAFANA_SERVICE_ACCOUNT_TOKEN=
GRAFANA_CLOUD_TOKEN=
GRAFANA_REMOTE_WRITE_URL=
GRAFANA_REMOTE_WRITE_USERNAME=
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USERNAME=

# ──────────────────────────────────────────────
# ClickHouse (optional analytics)
# ──────────────────────────────────────────────
CLICKHOUSE_ENABLED=false
CLICKHOUSE_URL=
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_ENDPOINT=
CLICKHOUSE_BATCH_SIZE=1000
CLICKHOUSE_FLUSH_INTERVAL=5s
CLICKHOUSE_EXPORT_ENABLED=false

# ──────────────────────────────────────────────
# Adaptive Concurrency
# ──────────────────────────────────────────────
ADAPTIVE_CONCURRENCY_MIN=5
ADAPTIVE_CONCURRENCY_MAX=100

# ──────────────────────────────────────────────
# App (Frontend)
# ──────────────────────────────────────────────
VITE_BASE_URL=http://localhost:5173
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
VITE_GOOGLE_CLIENT_ID=

# ──────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────
AUTH_DATABASE_URL=postgresql://strait:strait@localhost:5432/strait
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=

# ──────────────────────────────────────────────
# Google OAuth
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────
# GitHub OAuth
# ──────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ──────────────────────────────────────────────
# Stripe (billing)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_SCALE_MONTHLY_PRICE_ID=
STRIPE_SCALE_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_STARTER_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_GROWTH_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_LARGE_YEARLY_PRICE_ID=
STRIPE_ADDON_CONCURRENT_RUNS_PRICE_ID=
STRIPE_ADDON_MEMBERS_PRICE_ID=
STRIPE_ADDON_CRON_SCHEDULES_PRICE_ID=
STRIPE_ADDON_DATA_RETENTION_PRICE_ID=
STRIPE_ADDON_WEBHOOK_ENDPOINTS_PRICE_ID=
STRIPE_METER_ID=

# ──────────────────────────────────────────────
# Notify Email (AWS SES primary)
# ──────────────────────────────────────────────
NOTIFY_EMAIL_PROVIDER=ses
NOTIFY_EMAIL_NORMALIZE_ENABLED=true
NOTIFY_EMAIL_VERIFY_ENABLED=true
NOTIFY_EMAIL_VERIFY_MX=true
SES_REGION=us-east-1
SES_FROM_EMAIL=noreply@strait.dev
SES_CONFIGURATION_SET=
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_SESSION_TOKEN=

# ──────────────────────────────────────────────
# Resend (legacy notify + billing)
# ──────────────────────────────────────────────
RESEND_API_KEY=
RESEND_SUPPORT_EMAIL=noreply@strait.dev
RESEND_FROM_EMAIL=noreply@strait.dev

# ──────────────────────────────────────────────
# Upstash Redis
# ──────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────
# Cloudflare
# ──────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STRAIT_WEBSITE_TOKEN=

# ──────────────────────────────────────────────
# Public URLs
# ──────────────────────────────────────────────
PUBLIC_API_URL=http://localhost:8080
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_DASHBOARD_URL=http://localhost:5173
PUBLIC_DOCS_URL=
PUBLIC_GTM_ID=
PUBLIC_WEBSITE_URL=

# ──────────────────────────────────────────────
# PostHog
# ──────────────────────────────────────────────
POSTHOG_API_KEY=

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
BASEHUB_TOKEN=
NGROK_AUTHTOKEN=
