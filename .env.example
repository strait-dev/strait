# ======================================================
# MINIMUM REQUIRED (for local development / self-hosting)
# ======================================================
# These values are enough for local development with the Compose stack.
# Everything else below has defaults or enables optional integrations.
#
#   DATABASE_URL=postgres://strait:strait@localhost:15432/strait?sslmode=disable
#   REDIS_URL=redis://localhost:16379
#   SEQUIN_BASE_URL=http://localhost:7376
#   SEQUIN_CONSUMER_NAME=strait-cdc
#   SEQUIN_API_TOKEN=<generate: openssl rand -hex 32>
#   SEQUIN_WEBHOOK_SECRET=<generate: openssl rand -hex 32>
#   INTERNAL_SECRET=<generate: openssl rand -hex 32>
#   JWT_SIGNING_KEY=<generate: openssl rand -hex 32>
#   ENCRYPTION_KEY=<generate: openssl rand -base64 32>
#   SECRET_ENCRYPTION_KEY=<generate: openssl rand -base64 32>
#   BETTER_AUTH_SECRET=<generate: openssl rand -hex 32>
#
# For the full self-host walkthrough, see SELFHOST.md.
# Local Docker users normally do not need this file; `make dev` starts the
# shared Compose stack with safe defaults.
# ======================================================

# Strait — Unified Environment Variables
# Copy this file to .env for local development, or use
# ./packages/scripts/selfhost-init.sh to generate .env.selfhost for Compose.
# Never commit real .env or .env.selfhost files.

# ──────────────────────────────────────────────
# Core Configuration
# ──────────────────────────────────────────────
STRAIT_API_URL=http://localhost:8080
STRAIT_EDITION=community
STRAIT_ENV=development
DATABASE_URL=postgres://strait:strait@localhost:15432/strait?sslmode=disable
REDIS_URL=redis://localhost:16379
MODE=all
PORT=8080
LOG_LEVEL=info
LOG_FORMAT=text
# INTERNAL_SECRET: Required. Min 16 chars.
# Used for service-to-service auth between the API, workers, dashboard, and Sequin.
# Generate with: openssl rand -hex 32
INTERNAL_SECRET=local-dev-internal-secret-change-me
# JWT_SIGNING_KEY: min 32 chars. Used for SDK run tokens and SSE.
# Generate with: openssl rand -hex 32
JWT_SIGNING_KEY=local-dev-jwt-signing-key-change-me-32chars

# ──────────────────────────────────────────────
# Worker Configuration
# ──────────────────────────────────────────────
WORKER_CONCURRENCY=25
WORKER_DRAIN_TIMEOUT=30s
WORKER_QUEUE_SIZE=0
WORKER_PARTITIONS=
# Comma-separated weights for multi-node partitioned dequeue. Leave empty for single-node.
WORKER_PARTITION_WEIGHTS=
# Buffered capacity of the executor's internal run-lifecycle event channel.
# Raise if subscribers (metrics, pubsub) lag under bursty load.
WORKER_EVENT_CHANNEL_SIZE=1024

# Per-component deadline enforced by Scheduler.Stop. Components that fail to
# exit within this window are logged and counted via
# strait.scheduler.shutdown_timeouts_total.
SCHEDULER_COMPONENT_SHUTDOWN_TIMEOUT=15s

# Interval at which the scheduler samples per-project backpressure token
# buckets (project_rate_limits.tokens) to populate the
# strait.queue.backpressure_tokens_available gauge. Set to 0 to disable.
BACKPRESSURE_SAMPLER_INTERVAL=15s

# Per-project enqueue token bucket. Keep enabled in production unless an
# upstream limiter enforces equivalent tenant isolation.
BACKPRESSURE_ENABLED=true

# Initial burst capacity for projects without an explicit project_rate_limits
# row.
BACKPRESSURE_DEFAULT_MAX_TOKENS=1000

# Steady-state accepted enqueue refill rate per project for projects without an
# explicit project_rate_limits row.
BACKPRESSURE_DEFAULT_REFILL_PER_SEC=500

# Number of DB-backed project tokens each process reserves before serving
# single-run admissions from memory. Set to 1 for strict per-trigger DB
# accounting.
BACKPRESSURE_LOCAL_LEASE_SIZE=32

# Maximum number of project rate-limit rows sampled per tick. Defaults
# to 100; bump higher only if you have many active projects and need
# tighter dashboard coverage.
BACKPRESSURE_SAMPLER_N=100

# ──────────────────────────────────────────────
# Scheduler Configuration
# ──────────────────────────────────────────────
HEARTBEAT_INTERVAL=10s
REAPER_INTERVAL=30s
STALE_THRESHOLD=60s
POLLER_INTERVAL=1s
REAPER_DELETE_BATCH_SIZE=100
INDEX_MAINTENANCE_INTERVAL=24h
LOG_DRAIN_WORKER_INTERVAL=60s
DEBOUNCE_POLLER_INTERVAL=1s
# Terminal run archival: when enabled the reaper moves terminal runs out of
# the hot job_runs table into job_runs_archive. Disable only for testing.
TERMINAL_ARCHIVE_ENABLED=true
# Partition reclaim: re-creates detached partitions to free bloat. Disabled by
# default; enable on long-running self-hosted installs to reclaim disk space.
PARTITION_RECLAIM_ENABLED=false
PARTITION_RECLAIM_INTERVAL=24h
# Number of months of data to keep when reclaiming partitions.
PARTITION_RECLAIM_SAFETY_MONTHS=2

# ──────────────────────────────────────────────
# Database Pool Configuration
# ──────────────────────────────────────────────
# IMPORTANT: DB_MAX_CONNS must be >= WORKER_CONCURRENCY to avoid stalled workers.
# With N replicas, total connections = DB_MAX_CONNS * N. Ensure your Postgres
# max_connections exceeds this total.
DB_MAX_CONNS=50
DB_MIN_CONNS=10
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m
DB_HEALTH_CHECK_PERIOD=30s
DB_PGBOUNCER_MODE=false
DB_PGBOUNCER_PREPARED_STATEMENTS=false
DB_STATEMENT_TIMEOUT=30s
DB_TRACE_STATEMENTS=false

# ──────────────────────────────────────────────
# Database Safety Guardrails
# ──────────────────────────────────────────────
DB_IDLE_IN_TRANSACTION_TIMEOUT=30s
DB_LOCK_TIMEOUT=5s
DB_TRANSACTION_TIMEOUT=60s
DB_LONG_TXN_ALERT_THRESHOLD=60s
DB_WATCHDOG_INTERVAL=15s
DB_WATCHDOG_ENABLED=true
DB_BACKPRESSURE_DISABLED=false
DB_BACKPRESSURE_SAMPLE_INTERVAL=100ms
DB_BACKPRESSURE_ACQUIRE_WAIT_THRESHOLD=50ms
DB_BACKPRESSURE_OCCUPANCY_THRESHOLD=0.90

# ──────────────────────────────────────────────
# Queue Hardening
# ──────────────────────────────────────────────
QUEUE_PGQUE_MAINTENANCE_INTERVAL=30s
QUEUE_PGQUE_ROTATION_PERIOD=5m

# ──────────────────────────────────────────────
# gRPC Worker Plane
# ──────────────────────────────────────────────
# WORKER_DB_SYNC_INTERVAL must be > HEARTBEAT_INTERVAL and < STALE_THRESHOLD.
# The default is 15s with HEARTBEAT_INTERVAL=10s and STALE_THRESHOLD=60s.
WORKER_DB_SYNC_INTERVAL=15s
WORKER_HEARTBEAT_TIMEOUT=30s
WORKER_DISCONNECT_SWEEP_INTERVAL=30s
# DELETE /workers waits up to this long for worker-plane disconnect acknowledgement.
WORKER_DISCONNECT_ACK_TIMEOUT=5s
# gRPC Serve waits for pubsub readiness up to this startup budget.
GRPC_PUBSUB_STARTUP_TIMEOUT=30s

# ──────────────────────────────────────────────
# Dead Letter Queue (DLQ) Configuration
# ──────────────────────────────────────────────
DLQ_MAX_PER_PROJECT=10000
DLQ_MAX_PER_JOB=1000
# drop_oldest masks the oldest visible DLQ row; reject marks the new failure system_failed.
DLQ_OVERFLOW_POLICY=drop_oldest

# ──────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────
# RATE_LIMIT_* applies per IP. DEFAULT_API_KEY_* applies per API key.
# TRIGGER_RATE_LIMIT_* applies only to job trigger endpoints.
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
DEFAULT_API_KEY_RATE_LIMIT=1000
DEFAULT_API_KEY_RATE_WINDOW_SECS=60
TRIGGER_RATE_LIMIT_REQUESTS=10
TRIGGER_RATE_LIMIT_WINDOW=1m

# ──────────────────────────────────────────────
# Request Configuration
# ──────────────────────────────────────────────
REQUEST_TIMEOUT=30s
MAX_REQUEST_BODY_SIZE=1048576
MAX_BULK_TRIGGER_ITEMS=500

# ──────────────────────────────────────────────
# Job Defaults
# ──────────────────────────────────────────────
DEFAULT_JOB_MAX_ATTEMPTS=3
DEFAULT_JOB_TIMEOUT_SECS=300
DEFAULT_JOB_MAX_CONCURRENCY=0
# DEFAULT_RUN_TTL_SECS: 0 = runs are kept forever. >0 = auto-delete after N seconds.
DEFAULT_RUN_TTL_SECS=0
MAX_RESULT_SIZE=1048576
MAX_SNOOZE_COUNT=50

# ──────────────────────────────────────────────
# Executor Configuration
# ──────────────────────────────────────────────
EXECUTOR_HTTP_TIMEOUT=5m
EXECUTOR_IDLE_CONN_TIMEOUT=90s
EXECUTION_TRACE_MODE=off
ADAPTIVE_TIMEOUT_ENABLED=false
MAX_DEQUEUE_BATCH_SIZE=50
JOB_CACHE_TTL=5m
VERSION_CACHE_TTL=30m
RUN_VERSION_CACHE_TTL=10m
JOB_HEALTH_CACHE_TTL=5m
JOB_HEALTH_STATS_CACHE_TTL=5m
ENDPOINT_GUARD_CACHE_TTL=1s
ENDPOINT_HEALTH_SUCCESS_SAMPLE_INTERVAL=1s
ENDPOINT_CIRCUIT_SUCCESS_SAMPLE_INTERVAL=1s
JOB_DEPS_CACHE_TTL=5m
BATCH_FLUSH_INTERVAL=1s
MEMORY_PRESSURE_THRESHOLD_PCT=0

# ──────────────────────────────────────────────
# Cache Configuration
# ──────────────────────────────────────────────
# Redis remains required at startup. Cache operations fail open to L1/Postgres
# after startup, except auth confirms with Postgres when freshness is uncertain.
API_KEY_CACHE_TTL=60s
CACHE_STATUS_READMODEL_TTL=5m
CACHE_SHARED_DEDUPE_TTL=10m

# ──────────────────────────────────────────────
# Sequin CDC Configuration
# ──────────────────────────────────────────────
SEQUIN_ADMIN_PASSWORD=
SEQUIN_API_TOKEN=local-dev-sequin-api-token-change-me
SEQUIN_BASE_URL=http://localhost:7376
SEQUIN_CONSUMER_NAME=strait-cdc
SEQUIN_DATABASE_NAME=strait-db
SEQUIN_WEBHOOK_SECRET=local-dev-sequin-webhook-secret-change-me
SEQUIN_BATCH_SIZE=200
SEQUIN_WAIT_TIME_MS=5000
CDC_BATCH_SIZE=200
CDC_WAIT_TIME_MS=5000

# ──────────────────────────────────────────────
# CORS Configuration
# ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
TRUSTED_PROXIES=

# ──────────────────────────────────────────────
# Retention Configuration
# ──────────────────────────────────────────────
RUN_RETENTION_SHORT=720h
RUN_RETENTION_LONG=2160h
WORKFLOW_RUN_RETENTION_DAYS=30
WORKFLOW_RETENTION=720h
EVENT_TRIGGER_RETENTION_DAYS=
EVENT_TRIGGER_RETENTION=168h

# ──────────────────────────────────────────────
# Redis Sentinel Configuration
# ──────────────────────────────────────────────
REDIS_SENTINEL_MASTER=
REDIS_SENTINEL_ADDRS=

# Redis pool sizing. Defaults are explicit and bounded to keep per-pod
# connection counts predictable. Raise PoolSize for high-fanout SSE pods;
# raise timeouts only after measuring Redis latency under load.
REDIS_POOL_SIZE=30
REDIS_MIN_IDLE_CONNS=5
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_CONN_MAX_LIFETIME=30m

# ──────────────────────────────────────────────
# Workflow Configuration
# ──────────────────────────────────────────────
MAX_WORKFLOW_NESTING_DEPTH=10
WF_STALL_THRESHOLD=15m
WF_STALL_ACTION=reconcile
WF_MAX_STEP_CAP=100
WF_STEP_CONCURRENCY_LIMIT=0
DEPENDENCY_STATUS_CACHE_TTL=5s

# ──────────────────────────────────────────────
# SSE Configuration
# ──────────────────────────────────────────────
SSE_KEEPALIVE_INTERVAL=15s
SSE_MAX_CONNS=5000
SSE_MAX_CONNS_PER_PROJECT=100
SSE_MAX_CONN_DURATION=30m

# ──────────────────────────────────────────────
# Idempotency
# ──────────────────────────────────────────────
# When false (default), the API returns 503 if the idempotency store is
# unavailable, so requests are never executed twice during a DB outage.
# Set to true to fall through to the handler (no dedupe) instead.
IDEMPOTENCY_FAIL_OPEN=false
# How long the middleware waits for DeleteIdempotencyKey when releasing
# a pending row after panic/non-2xx/overflow.
IDEMPOTENCY_CLEANUP_TIMEOUT=5s

# ──────────────────────────────────────────────
# Webhook Configuration
# ──────────────────────────────────────────────
WEBHOOK_TIMEOUT=10s
WEBHOOK_IDLE_CONN_TIMEOUT=60s
WEBHOOK_DISPATCH_TIMEOUT=15s
WEBHOOK_MAX_PAYLOAD_BYTES=1048576
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_CONCURRENCY=50
WEBHOOK_BATCH_ENABLED=false
WEBHOOK_MAX_BATCH_SIZE=50
WEBHOOK_MAX_IDLE_CONNS=100
WEBHOOK_MAX_IDLE_CONNS_PER_HOST=50
WEBHOOK_REQUIRE_TLS=false

# ──────────────────────────────────────────────
# Orchestration Runtime
# ──────────────────────────────────────────────
# Strait is orchestration-only: workers connect via gRPC streaming and execute
# jobs in their own processes. There is no built-in container runtime.
DEFAULT_REGION=iad
# EXTERNAL_API_URL is the base URL workers use to call back to the Strait API.
EXTERNAL_API_URL=http://localhost:8080

# ──────────────────────────────────────────────
# Security & Access Control
# ──────────────────────────────────────────────
ALLOW_PRIVATE_ENDPOINTS=false
# Require https for job endpoint and fallback endpoint URLs. Job dispatch injects
# decrypted secrets and the run-token JWT, so enable this to refuse plaintext
# http endpoints. Default false preserves http for self-host/dev topologies.
ENDPOINT_REQUIRE_TLS=false
# Cloud non-development deployments require this to be true so launch plan
# gates, run limits, and worker billing enforcement cannot silently fail open.
BILLING_ENFORCEMENT_ENABLED=false
BILLING_ENTITLEMENTS_AUTHORITATIVE=true
DISABLE_EMAIL_VERIFICATION=false
DISABLE_STRIPE_BILLING=false
PERMISSION_CACHE_TTL=
# How long to cache per-project quotas before refetching from Postgres.
# Quotas change rarely (admin updates, billing plan changes) so a short
# TTL is a safe trade-off against fresh reads on every trigger/SDK call.
# Set to 0 to disable. Default: 60s.
PROJECT_QUOTA_CACHE_TTL=

# ──────────────────────────────────────────────
# Encryption Configuration
# ──────────────────────────────────────────────
# ENCRYPTION_KEY protects encrypted application data. Generate with:
# openssl rand -base64 32
ENCRYPTION_KEY=
ENCRYPTION_KEY_OLD=
# SECRET_ENCRYPTION_KEY encrypts job secrets at rest. Required for the
# /v1/secrets/ endpoints. Falls back to ENCRYPTION_KEY if unset. Generate
# with: openssl rand -base64 32
SECRET_ENCRYPTION_KEY=

# ──────────────────────────────────────────────
# Audit Events
# ──────────────────────────────────────────────
# Default retention in days for audit events. Per-project overrides live in
# project_quotas.audit_retention_days; 0 on a project disables trim for it.
AUDIT_RETENTION_DEFAULT_DAYS=365
# Size of the in-memory async emit buffer. Must be >= 256.
AUDIT_ASYNC_BUFFER_SIZE=16384
# SIEM forwarding. Leave AUDIT_SIEM_ENDPOINT blank to disable. When set,
# AUDIT_SIEM_AUTH_TOKEN is required (sent as Authorization: Bearer ...).
AUDIT_SIEM_ENDPOINT=
AUDIT_SIEM_AUTH_TOKEN=
AUDIT_SIEM_BATCH_SIZE=100
AUDIT_SIEM_FLUSH_INTERVAL=10s
# Default cap on rows per audit export call. Per-project overrides live in
# project_quotas.audit_export_row_cap.
AUDIT_EXPORT_ROW_CAP_DEFAULT=1000000
# Max DLQ rows the reclaimer processes per scheduler tick.
AUDIT_DLQ_RECLAIM_BATCH=200
# Max days a deadletter row may live before the retention reaper drops it.
# 0 disables the sweep (rows kept forever for manual triage). Default: 30.
AUDIT_DLQ_MAX_AGE_DAYS=30
# Max retry attempts the reclaimer will make per DLQ row before skipping.
# 0 disables the cap (legacy behavior). Skipped rows stay in DLQ for triage.
AUDIT_DLQ_MAX_RECLAIM_ATTEMPTS=10

# ──────────────────────────────────────────────
# OIDC / OAuth Configuration
# Go API uses OIDC_PUBLIC_KEY_PEM to verify JWTs.
# TanStack app uses OIDC_PRIVATE_KEY_PEM to sign JWTs.
# Both share the same OIDC_ISSUER and OIDC_AUDIENCE values.
# ──────────────────────────────────────────────
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_PUBLIC_KEY_PEM=
OIDC_PRIVATE_KEY_PEM=

# ──────────────────────────────────────────────
# Database Migrations
# ──────────────────────────────────────────────
MIGRATION_MODE=auto
MIGRATION_LOCK_TIMEOUT=30s
DEBUG_STATSVIZ=false

# ──────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────
# Logs: app sends OTLP to the OTel Collector, which routes to Grafana Cloud Loki.
# Traces: app sends OTLP to the OTel Collector, which routes to ClickHouse.
# Metrics: /metrics endpoint scraped by OTel Collector, forwarded to Grafana Cloud.
# Errors: Sentry SDK captures error-level logs with stack traces.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTLP_METRIC_ENDPOINT=
OTLP_METRIC_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=
SENTRY_DEBUG=false
SENTRY_MAX_BREADCRUMBS=100
SENTRY_MAX_SPANS=1000
SENTRY_MAX_ERROR_DEPTH=100
SENTRY_STRICT_TRACE_CONTINUATION=false
SENTRY_SCHEDULER_CHECKINS=false
SENTRY_SCHEDULER_CHECKIN_PREFIX=strait-scheduler
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
STRAIT_PROFILING_ENABLED=false
# Keep pprof on the API listener when STRAIT_PROFILING_ENABLED=true.
STRAIT_PROFILING_API_ENABLED=true
# Optional localhost-only management listener with only pprof routes.
STRAIT_PROFILING_MANAGEMENT_ENABLED=false
STRAIT_PROFILING_MANAGEMENT_BIND_ADDR=127.0.0.1
STRAIT_PROFILING_MANAGEMENT_PORT=18080
# Process-wide runtime profiling sampling rates. Set either to 0 to disable.
STRAIT_PROFILING_MUTEX_FRACTION=100
STRAIT_PROFILING_BLOCK_RATE=100000
# Optional. When set, pprof requires this secret instead of INTERNAL_SECRET.
STRAIT_PROFILING_SECRET=
# Optional comma-separated CIDR/IP allowlist for pprof callers.
STRAIT_PROFILING_ALLOWED_CIDRS=
PYROSCOPE_ENDPOINT=
PYROSCOPE_AUTH_TOKEN=

# ──────────────────────────────────────────────
# Grafana Cloud
# ──────────────────────────────────────────────
GRAFANA_URL=
GRAFANA_SERVICE_ACCOUNT_TOKEN=
GRAFANA_CLOUD_TOKEN=
GRAFANA_REMOTE_WRITE_URL=
GRAFANA_REMOTE_WRITE_USERNAME=
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USERNAME=

# ──────────────────────────────────────────────
# ClickHouse (optional analytics)
# ──────────────────────────────────────────────
CLICKHOUSE_ENABLED=false
CLICKHOUSE_URL=
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_ENDPOINT=
CLICKHOUSE_BATCH_SIZE=1000
CLICKHOUSE_FLUSH_INTERVAL=5s
CLICKHOUSE_EXPORT_ENABLED=false

# ──────────────────────────────────────────────
# Adaptive Concurrency
# ──────────────────────────────────────────────
ADAPTIVE_CONCURRENCY_MIN=5
ADAPTIVE_CONCURRENCY_MAX=100

# ──────────────────────────────────────────────
# App (Frontend)
# ──────────────────────────────────────────────
VITE_BASE_URL=http://localhost:5173
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
VITE_GOOGLE_CLIENT_ID=

# ──────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────
AUTH_DATABASE_URL=postgresql://strait:strait@localhost:15432/strait
BETTER_AUTH_URL=http://localhost:5173
# BETTER_AUTH_SECRET: Required. Min 32 chars.
# Used by Better Auth for signing session tokens and cookies.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# ──────────────────────────────────────────────
# Google OAuth
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────
# GitHub OAuth
# ──────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ──────────────────────────────────────────────
# Stripe (billing)
# ──────────────────────────────────────────────
# Use sk_test_... keys for sandbox / staging; sk_live_... for production.
# Cloud non-development deployments require STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ENTERPRISE_STARTER_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_GROWTH_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_LARGE_YEARLY_PRICE_ID=
STRIPE_METER_ID=
#
# Orchestration-tier price IDs (flat monthly subscription per plan).
# Wave 2 onwards, the catalog resolver fetches Stripe Price IDs via
# lookup_keys at runtime, so these variables are only needed for code
# paths that have not yet migrated to the resolver. Lookup keys are the
# canonical identifiers:
#   strait_{free,starter,pro,scale,business}_monthly
#   strait_{starter,pro,scale,business}_annual
#   strait_overage_{free,starter,pro,scale,business} (graduated tiers, metered)
#
# Real sandbox / live price IDs and the migration playbook are recorded
# in the internal Notion "Stripe Catalog Snapshot" page; do not paste
# them into this repo.
STRIPE_FREE_PRICE_ID=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
# Overage meter price IDs (graduated metered billing — no charge until the
# plan's included allowance is exceeded; per-run rate above that).
STRIPE_FREE_OVERAGE_PRICE_ID=
STRIPE_STARTER_OVERAGE_PRICE_ID=
STRIPE_PRO_OVERAGE_PRICE_ID=
STRIPE_SCALE_OVERAGE_PRICE_ID=
STRIPE_BUSINESS_OVERAGE_PRICE_ID=
# ──────────────────────────────────────────────
# Prometheus uptime source (SLA credit calculator)
# ──────────────────────────────────────────────
# When PROMETHEUS_QUERY_URL is unset the SLACalculator pins to a 100%
# static uptime source, which keeps community / dev deployments quiet.
# When set, the calculator runs PROMETHEUS_UPTIME_QUERY as an instant
# query at the end of each billing period. The default query is
# service-level (Strait's `up` metric); swap in a per-tenant query when
# that aggregation is plumbed in.
PROMETHEUS_QUERY_URL=
PROMETHEUS_UPTIME_QUERY=avg_over_time(up{job="strait"}[30d]) * 100

# ──────────────────────────────────────────────
# Resend (email)
# ──────────────────────────────────────────────
RESEND_API_KEY=
RESEND_SUPPORT_EMAIL=noreply@strait.dev
RESEND_FROM_EMAIL=noreply@strait.dev

# ──────────────────────────────────────────────
# Upstash Redis
# ──────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────
# Public URLs
# ──────────────────────────────────────────────
PUBLIC_API_URL=http://localhost:8080
PUBLIC_APP_URL=http://localhost:5173

# ──────────────────────────────────────────────
# PostHog
# ──────────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ──────────────────────────────────────────────
# gRPC Worker streaming server
# ──────────────────────────────────────────────
GRPC_ENABLED=true
GRPC_BIND_ADDR=127.0.0.1
GRPC_PORT=50051
GRPC_ALLOW_PLAINTEXT=false
# Optional TLS for self-hosted deployments (cloud terminates TLS at NLB).
GRPC_TLS_CERT_PATH=
GRPC_TLS_KEY_PATH=
GRPC_KEEPALIVE_TIME=30s
GRPC_KEEPALIVE_TIMEOUT=10s

# ──────────────────────────────────────────────
# Pentest tooling (operator-gated)
# ──────────────────────────────────────────────
# The `seed-pentest` and `revoke-pentest` subcommands ship in every binary but
# refuse to run unless STRAIT_PENTEST_MODE=1 is set AND --confirm-pentest is
# passed on the command line. Leave this empty in production; set to "1" only
# on the sandbox where you intend to run pentest fixtures.
STRAIT_PENTEST_MODE=
# Loopback hosts (localhost / 127.0.0.1 / ::1) are not in the default
# pentest DB-host allowlist because sidecar-proxy production topologies route
# DB traffic through 127.0.0.1; a stray DATABASE_URL there would otherwise
# slip the safety rail. Set to "1" for local dev that genuinely targets a
# loopback sandbox database.
STRAIT_PENTEST_ALLOW_LOOPBACK=

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
NGROK_AUTHTOKEN=
