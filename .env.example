# Core Configuration
DATABASE_URL=postgres://strait:strait@localhost:5432/strait?sslmode=disable
REDIS_URL=redis://localhost:6379
MODE=all
PORT=8080
LOG_LEVEL=info
INTERNAL_SECRET=your-internal-secret-32-chars-minimum
JWT_SIGNING_KEY=your-jwt-signing-key-32-chars-minimum

# Worker Configuration
WORKER_CONCURRENCY=10
WORKER_DRAIN_TIMEOUT=30s
WORKER_QUEUE_SIZE=0
WORKER_PARTITIONS=
WORKER_PARTITION_WEIGHTS=

# Scheduler Configuration
HEARTBEAT_INTERVAL=10s
REAPER_INTERVAL=30s
STALE_THRESHOLD=60s
POLLER_INTERVAL=5s
REAPER_DELETE_BATCH_SIZE=100
INDEX_MAINTENANCE_INTERVAL=24h
LOG_DRAIN_WORKER_INTERVAL=60s

# Database Pool Configuration
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m
DB_PGBOUNCER_MODE=false

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
TRIGGER_RATE_LIMIT_REQUESTS=10
TRIGGER_RATE_LIMIT_WINDOW=1m

# Request Configuration
REQUEST_TIMEOUT=30s
MAX_REQUEST_BODY_SIZE=1048576
MAX_BULK_TRIGGER_ITEMS=500

# Sequin CDC Configuration
SEQUIN_BASE_URL=
SEQUIN_CONSUMER_NAME=
SEQUIN_API_TOKEN=
SEQUIN_BATCH_SIZE=10
SEQUIN_WAIT_TIME_MS=5000
CDC_BATCH_SIZE=10
CDC_WAIT_TIME_MS=5000

# CORS Configuration
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

# Retention Configuration
RUN_RETENTION_SHORT=720h
RUN_RETENTION_LONG=2160h
WORKFLOW_RUN_RETENTION_DAYS=30
WORKFLOW_RETENTION=720h
EVENT_TRIGGER_RETENTION_DAYS=
EVENT_TRIGGER_RETENTION=168h

# Redis Sentinel Configuration
REDIS_SENTINEL_MASTER=
REDIS_SENTINEL_ADDRS=

# Workflow Configuration
MAX_WORKFLOW_NESTING_DEPTH=10
WF_STALL_THRESHOLD=15m
WF_STALL_ACTION=log_only
WF_MAX_STEP_CAP=0
WF_STEP_CONCURRENCY_LIMIT=0
DEPENDENCY_STATUS_CACHE_TTL=5s

# SSE Configuration
SSE_KEEPALIVE_INTERVAL=15s

# Worker/Executor Timeouts
WEBHOOK_TIMEOUT=10s
WEBHOOK_IDLE_CONN_TIMEOUT=60s
WEBHOOK_DISPATCH_TIMEOUT=15s
WEBHOOK_MAX_PAYLOAD_BYTES=1048576
WEBHOOK_MAX_ATTEMPTS=3
EXECUTOR_HTTP_TIMEOUT=5m
EXECUTOR_IDLE_CONN_TIMEOUT=90s
DEFAULT_JOB_MAX_ATTEMPTS=3
DEFAULT_JOB_TIMEOUT_SECS=300

# Managed Execution (Fly Machines)
COMPUTE_RUNTIME=none
FLY_API_TOKEN=
FLY_APP_NAME=
FLY_REGION=iad
EXTERNAL_API_URL=
MAX_CONCURRENT_MACHINES=10
WARM_POOL_ENABLED=false
WARM_POOL_MAX_PER_JOB=3
WARM_POOL_TTL=5m

# Encryption Configuration
ENCRYPTION_KEY=
ENCRYPTION_KEY_OLD=
SECRET_ENCRYPTION_KEY=

# OIDC Configuration
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_PUBLIC_KEY_PEM=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
PERMISSION_CACHE_TTL=

# Adaptive Concurrency
ADAPTIVE_CONCURRENCY_MIN=5
ADAPTIVE_CONCURRENCY_MAX=100
