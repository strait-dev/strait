{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": [
    "@manypkg/cli",
    "@typescript/native-preview"
  ],
  "ignoreWorkspaces": ["apps/website", "apps/strait", "packages/*"],
  "ignore": ["sdk/**"],
  "workspaces": {
    "apps/docs": {
      "entry": ["source.config.ts"]
    }
  },
  "rules": {
    "unlisted": "off",
    "exports": "warn",
    "types": "warn"
  }
}
