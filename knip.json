{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": [
    "@manypkg/cli",
    "@typescript/native-preview",
    "better-auth",
    "@commitlint/config-conventional"
  ],
  "ignoreWorkspaces": ["apps/website", "apps/strait", "packages/*"],
  "ignore": ["commitlint.config.js", "sdk/**"],
  "rules": {
    "unlisted": "off",
    "exports": "warn",
    "types": "warn"
  }
}
