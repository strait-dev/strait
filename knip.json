{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": [
    "@manypkg/cli",
    "@typescript/native-preview",
    "openapi-typescript"
  ],
  "ignoreWorkspaces": ["apps/strait", "apps/app", "packages/*"],
  "ignoreBinaries": ["go"],
  "workspaces": {
    "apps/docs": {
      "entry": ["docs.json"]
    }
  },
  "rules": {
    "unlisted": "off",
    "exports": "warn",
    "types": "warn"
  }
}
