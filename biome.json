{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.{ts,tsx,js,jsx,json,css}",
      "**/convex/**/*.ts",
      "!node_modules",
      "!.turbo",
      "!tanstack",
      "!dist",
      "!build",
      "!**/_generated",
      "!**/routeTree.gen.ts",
      "!apps/app/src/lib/api/schema.d.ts",
      "!**/.agents/skills"
    ]
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "correctness": {
        "noUnusedVariables": {
          "level": "error",
          "fix": "none"
        },
        "noUnresolvedImports": "off",
        "useImportExtensions": "off"
      },
      "style": {
        "useFilenamingConvention": "off",
        "useConsistentTypeDefinitions": "off"
      },
      "a11y": {
        "noSvgWithoutTitle": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "noNamespaceImport": "off",
        "noImgElement": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noUnknownAtRules": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/routeTree.gen.ts", "**/_generated/**"],
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": ["**/hooks/**/*.ts", "**/hooks/**/*.tsx"]
    },
    {
      "includes": ["**/lib/export/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noMagicNumbers": "off",
            "noNestedTernary": "off",
            "useDefaultSwitchClause": "off"
          }
        }
      }
    },
    {
      "includes": ["**/workflows/**/*.ts", "**/convex/**/*.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "style": {
            "noMagicNumbers": "off"
          },
          "suspicious": {
            "noImplicitAnyLet": "off",
            "noEvolvingTypes": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/lib/editor/**/*.ts",
        "**/lib/editor/**/*.tsx",
        "**/components/editor/**/*.tsx"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.scss"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnknownTypeSelector": "off"
          }
        }
      }
    },
    {
      "includes": ["**/e2e/**/*.ts"],
      "linter": {
        "rules": {
          "performance": {
            "useTopLevelRegex": "off"
          }
        }
      }
    }
  ]
}
