{
  "name": "strait",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "description": "Strait monorepo with app, website, and shared packages.",
  "author": "Leonardo Maldonado <leonardomso11@gmail.com>",
  "scripts": {
    "start": "turbo run start --no-cache --parallel --continue",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo lint && bun run manypkg check",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:fix:unsafe": "knip --fix --allow-remove-files",
    "manypkg:check": "bun run manypkg check",
    "manypkg:fix": "bun run manypkg fix",
    "biome:lint": "turbo biome:lint",
    "biome:format": "turbo biome:format",
    "biome:write": "turbo biome:write",
    "biome:fix:unsafe": "turbo biome:fix:unsafe",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "run-all": "bun run manypkg:fix && bun run manypkg:check && bun run biome:format && bun run biome:write && bun run biome:fix:unsafe && bun run biome:lint && bun run typecheck",
    "sdk:run-all": "bun run --filter @strait/ts run-all && make -C packages/go-sdk run-all && make -C packages/python-sdk run-all",
    "update-all": "bunx npm-check-updates -ui -ws",
    "release": "changeset version && bash scripts/sync-sdk-versions.sh",
    "deploy": "cd apps/strait && make deploy",
    "deploy:staging": "cd apps/strait && make deploy-staging",
    "deploy:sequin": "cd deploy/sequin && fly deploy -a strait-sequin"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@changesets/cli": "^2.30.0",
    "@manypkg/cli": "^0.25.1",
    "@typescript/native-preview": "^7.0.0-dev.20260324.1",
    "knip": "^6.0.4",
    "lefthook": "^2.1.4",
    "openapi-typescript": "^7.13.0",
    "turbo": "^2.8.20",
    "ultracite": "7.3.2"
  }
}
