{
  "name": "strait",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "description": "Strait monorepo with app, website, and shared packages.",
  "author": "Leonardo Maldonado <leonardomso11@gmail.com>",
  "scripts": {
    "start": "turbo run start --no-cache --parallel --continue",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo lint && bun run manypkg check",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:fix:unsafe": "knip --fix --allow-remove-files",
    "manypkg:check": "bun run manypkg check",
    "manypkg:fix": "bun run manypkg fix",
    "biome:lint": "turbo biome:lint",
    "biome:format": "turbo biome:format",
    "biome:write": "turbo biome:write",
    "biome:fix:unsafe": "turbo biome:fix:unsafe",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "run-all": "bun run manypkg:fix && bun run manypkg:check && bun run biome:format && bun run biome:write && bun run biome:fix:unsafe && bun run biome:lint && bun run typecheck",
    "update-all": "bunx npm-check-updates -ui -ws"
  },
  "overrides": {
    "better-auth": "1.5.5",
    "@tanstack/query-core": "5.90.20",
    "@tanstack/react-query": "5.90.21"
  },
  "devDependencies": {
    "@better-auth/passkey": "^1.5.5",
    "@biomejs/biome": "2.4.7",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@manypkg/cli": "^0.25.1",
    "@typescript/native-preview": "^7.0.0-dev.20260315.1",
    "baseline-browser-mapping": "^2.10.8",
    "better-auth": "^1.5.5",
    "knip": "^5.86.0",
    "lefthook": "^2.1.4",
    "turbo": "^2.8.17",
    "ultracite": "7.3.1"
  }
}
