{
  "name": "strait",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "description": "Strait monorepo with app, website, and shared packages.",
  "author": "Leonardo Maldonado <leonardomso11@gmail.com>",
  "scripts": {
    "start": "turbo run start --no-cache --parallel --continue",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo lint && bun run manypkg check",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:fix:unsafe": "knip --fix --allow-remove-files",
    "manypkg:check": "bun run manypkg check",
    "manypkg:fix": "bun run manypkg fix",
    "biome:lint": "turbo biome:lint",
    "biome:format": "turbo biome:format",
    "biome:write": "turbo biome:write",
    "biome:fix:unsafe": "turbo biome:fix:unsafe",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "go:build": "cd apps/strait && go build ./...",
    "go:vet": "cd apps/strait && go vet ./...",
    "go:lint": "cd apps/strait && golangci-lint run --timeout=5m ./...",
    "go:test": "cd apps/strait && go test ./... -short -count=1 -race -timeout=300s",
    "go:run-all": "bun run go:lint",
    "run-all": "bun run manypkg:fix && bun run manypkg:check && bun run biome:format && bun run biome:write && bun run biome:fix:unsafe && bun run biome:lint && bun run typecheck && bun run go:lint",
    "update-all": "bunx npm-check-updates -ui -ws",
    "release": "changeset version",
    "deploy:app": "cd apps/app && bun run deploy",
    "deploy:website": "cd apps/website && bun run deploy"
  },
  "overrides": {
    "h3": "1.15.9",
    "smol-toml": ">=1.6.1",
    "kysely": ">=0.28.14",
    "socket.io-parser": ">=4.2.6",
    "fast-xml-parser": ">=5.5.7",
    "serialize-javascript": ">=7.0.3",
    "yaml": ">=2.8.3",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/cli": "^2.30.0",
    "@manypkg/cli": "^0.25.1",
    "@typescript/native-preview": "^7.0.0-dev.20260405.1",
    "knip": "^6.3.0",
    "lefthook": "^2.1.4",
    "openapi-typescript": "^7.13.0",
    "turbo": "^2.9.4",
    "ultracite": "7.4.3"
  }
}
