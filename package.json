{
  "name": "strait",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/billing",
    "packages/config",
    "packages/transactional",
    "apps/*"
  ],
  "description": "Strait monorepo with app and shared packages.",
  "author": "Leonardo Maldonado <leonardomso11@gmail.com>",
  "scripts": {
    "start": "turbo run start --no-cache --parallel --continue",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo lint && bun run manypkg check",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "typecheck:affected": "turbo typecheck --affected",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:fix:unsafe": "knip --fix --allow-remove-files",
    "manypkg:check": "bun run manypkg check",
    "manypkg:fix": "bun run manypkg fix",
    "biome:lint": "turbo biome:lint",
    "biome:format": "turbo biome:format",
    "biome:write": "turbo biome:write",
    "biome:fix:unsafe": "turbo biome:fix:unsafe",
    "billing:catalog:check": "bun run --cwd packages/billing check:generated",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "go:build": "cd apps/strait && go build ./...",
    "go:vet": "cd apps/strait && go vet ./...",
    "go:lint": "cd apps/strait && ./scripts/lint-go.sh",
    "go:test": "cd apps/strait && go test ./... -short -count=1 -race -timeout=300s",
    "go:test:integration:fast": "cd apps/strait && ./scripts/test-integration-fast.sh --all",
    "go:test:integration:clean": "cd apps/strait && ./scripts/test-integration-clean.sh",
    "go:run-all": "bun run go:lint",
    "run-all": "bun run manypkg:fix && bun run manypkg:check && bun run biome:fix:unsafe && bun run typecheck",
    "update-all": "bunx npm-check-updates -ui -ws",
    "deploy:app": "cd apps/app && bun run deploy",
    "doctor": "react-doctor"
  },
  "overrides": {
    "@tanstack/query-core": "5.100.10",
    "h3": "2.0.1-rc.22",
    "smol-toml": ">=1.6.1",
    "kysely": ">=0.28.14",
    "socket.io-parser": ">=4.2.6",
    "fast-xml-parser": ">=5.5.7",
    "serialize-javascript": ">=7.0.3",
    "yaml": ">=2.8.3",
    "picomatch": "4.0.4",
    "shell-quote": ">=1.9.0"
  },
  "trustedDependencies": [],
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@manypkg/cli": "^0.25.1",
    "@typescript/native-preview": "^7.0.0-dev.20260628.1",
    "knip": "^6.23.0",
    "lefthook": "^2.1.9",
    "openapi-typescript": "^7.13.0",
    "react-doctor": "0.6.0",
    "turbo": "^2.10.0",
    "ultracite": "7.8.3"
  }
}
