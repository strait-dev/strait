    "CLICKHOUSE_ENDPOINT",
    "CLICKHOUSE_DATABASE",
    "CLICKHOUSE_BATCH_SIZE",
    "CLICKHOUSE_FLUSH_INTERVAL",

    "GRAFANA_URL",
    "GRAFANA_SERVICE_ACCOUNT_TOKEN",
    "GRAFANA_CLOUD_TOKEN",
    "GRAFANA_REMOTE_WRITE_URL",
    "GRAFANA_REMOTE_WRITE_USERNAME",
    "GRAFANA_LOKI_URL",
    "GRAFANA_LOKI_USERNAME",

    "ADAPTIVE_CONCURRENCY_MIN",
