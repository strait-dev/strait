    "VITE_BASE_URL",
    "VITE_SENTRY_DSN",
    "VITE_SENTRY_ENVIRONMENT",
    "VITE_POSTHOG_KEY",
    "VITE_POSTHOG_HOST",
    "VITE_GOOGLE_CLIENT_ID",
    "NEXT_PUBLIC_DASHBOARD_URL",

    "AUTH_DATABASE_URL",
    "BETTER_AUTH_URL",
    "BETTER_AUTH_SECRET",

    "GOOGLE_CLIENT_ID",
