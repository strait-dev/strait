{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "AUTH_DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "INTERNAL_SECRET",
    "NGROK_AUTHTOKEN",
    "OIDC_AUDIENCE",
    "OIDC_ISSUER",
    "OIDC_PRIVATE_KEY_PEM",
    "OIDC_PUBLIC_KEY_PEM",
    "RESEND_API_KEY",
    "RESEND_SUPPORT_EMAIL",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "STRAIT_APP_TARGET",
    "STRAIT_API_URL",
    "STRIPE_ENTERPRISE_GROWTH_YEARLY_PRICE_ID",
    "STRIPE_ENTERPRISE_LARGE_YEARLY_PRICE_ID",
    "STRIPE_ENTERPRISE_STARTER_YEARLY_PRICE_ID",
    "STRIPE_PRO_MONTHLY_PRICE_ID",
    "STRIPE_PRO_YEARLY_PRICE_ID",
    "STRIPE_SCALE_MONTHLY_PRICE_ID",
    "STRIPE_SCALE_YEARLY_PRICE_ID",
    "STRIPE_SECRET_KEY",
    "STRIPE_STARTER_MONTHLY_PRICE_ID",
    "STRIPE_STARTER_YEARLY_PRICE_ID",
    "UPSTASH_REDIS_REST_TOKEN",
    "UPSTASH_REDIS_REST_URL",
    "VITE_BASE_URL",
    "VITE_GOOGLE_CLIENT_ID",
    "VITE_POSTHOG_HOST",
    "VITE_POSTHOG_KEY",
    "VITE_SENTRY_DSN",
    "VITE_SENTRY_ENVIRONMENT",
    "VITE_STRAIT_EDITION"
  ],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "dependsOn": ["^build"],
      "outputs": [".output/**", "dist/**"]
    },
    "start": {
      "cache": false
    },
    "test": {
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:unit": {
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:e2e": {
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false
    },
    "dev": {
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "persistent": true,
      "cache": false
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.md",
        "!**/*.mdx",
        "!**/CHANGELOG.md",
        "!**/LICENSE*",
        "!**/*.txt"
      ],
      "outputs": []
    },
    "biome:format": {
      "outputs": []
    },
    "biome:write": {
      "outputs": []
    },
    "biome:fix:unsafe": {
      "outputs": []
    },
    "biome:lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
