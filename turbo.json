    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",

    "POLAR_ACCESS_TOKEN",
    "POLAR_SERVER",
    "POLAR_APP_WEBHOOK_SECRET",
    "POLAR_API_WEBHOOK_SECRET",
    "POLAR_STARTER_MONTHLY_ID",
    "POLAR_STARTER_YEARLY_ID",
    "POLAR_PRO_MONTHLY_ID",
    "POLAR_PRO_YEARLY_ID",
    "POLAR_PROFESSIONAL_MONTHLY_ID",
    "POLAR_PROFESSIONAL_YEARLY_ID",

    "RESEND_API_KEY",
    "RESEND_SUPPORT_EMAIL",
    "RESEND_FROM_EMAIL",

    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",

    "BASEHUB_TOKEN",
    "NGROK_AUTHTOKEN",

    "TURBO_TEAM",
    "TURBO_TOKEN"
  ],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "next-env.d.ts",
        ".expo/**",
        ".output/**",
        ".vercel/output/**",
        "dist/**"
      ]
    },
    "start": {
      "cache": false
    },
    "test": {
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:unit": {
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:e2e": {
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false
    },
    "dev": {
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "persistent": true,
      "cache": false
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "biome:format": {
      "outputs": []
    },
    "biome:write": {
      "outputs": []
    },
    "biome:fix:unsafe": {
      "outputs": []
    },
    "biome:lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
