{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/server.ts!",
    "src/router.tsx!",
    "src/routes/**/*.{ts,tsx}!",
    "server/routes/**/*.{ts,tsx}!"
  ],
  "project": [
    "src/**/*.{ts,tsx}!",
    "!src/routeTree.gen.ts",
    "!**/*.test.{ts,tsx}",
    "!**/*.spec.{ts,tsx}"
  ],
  "paths": {
    "@/*": ["./src/*"],
    "@strait/ui/*": ["../../packages/ui/src/*"],
    "@strait/transactional": ["../../packages/transactional/src/index.ts"]
  },
  "ignoreDependencies": [],
  "ignoreBinaries": ["biome"],
  "includeEntryExports": false,
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "rules": {
    "unlisted": "off",
    "exports": "warn",
    "types": "warn"
  },
  "vite": true,
  "vitest": {
    "config": ["vitest.config.ts"]
  }
}
