{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/start.ts!",
    "src/router.tsx!",
    "src/routes/**/*.{ts,tsx}!",
    "postcss.config.mjs"
  ],
  "project": [
    "src/**/*.{ts,tsx}!",
    "!src/routeTree.gen.ts",
    "!**/*.test.{ts,tsx}",
    "!**/*.spec.{ts,tsx}"
  ],
  "paths": {
    "@/*": ["./src/*"],
    "@strait/ui/*": ["../../packages/ui/src/*"],
    "@strait/transactional": ["../../packages/transactional/src/index.ts"],
    "@strait/utils": ["../../packages/utils/src/index"]
  },
  "ignoreDependencies": [
    "@strait/ui",
    "@strait/transactional",
    "@strait/utils",
    "@tailwindcss/postcss",
    "@radix-ui/react-accordion"
  ],
  "ignoreBinaries": ["biome"],
  "includeEntryExports": false,
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "rules": {
    "unlisted": "off",
    "exports": "warn",
    "types": "warn"
  },
  "vite": true,
  "vitest": {
    "config": ["vitest.config.ts"]
  }
}
