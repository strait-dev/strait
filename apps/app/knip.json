{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/server.ts!", "src/router.tsx!", "src/routes/**/*.{ts,tsx}!"],
  "project": [
    "src/**/*.{ts,tsx}!",
    "!src/routeTree.gen.ts",
    "!**/*.test.{ts,tsx}",
    "!**/*.spec.{ts,tsx}"
  ],
  "paths": {
    "@/*": ["./src/*"],
    "@strait/transactional": ["../../packages/transactional/src/index.ts"]
  },
  "ignoreDependencies": ["@sentry/cli"],
  "ignoreBinaries": ["biome", "go", "openapi-typescript"],
  "includeEntryExports": false,
  "ignoreExportsUsedInFile": true,
  "rules": {
    "unlisted": "off",
    "exports": "warn",
    "types": "warn"
  },
  "vite": true,
  "vitest": {
    "config": ["vitest.config.ts"]
  }
}
