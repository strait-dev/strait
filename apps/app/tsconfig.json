{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@strait/app",
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/*"],
      "@strait/billing": ["../../packages/billing/src/products.ts"],
      "@strait/billing/products": ["../../packages/billing/src/products.ts"],
      "@strait/db/*": ["../../packages/db/src/*"],
      "@strait/utils": ["../../packages/utils/src/index"],
      "@strait/transactional": ["../../packages/transactional/emails/index.ts"],
      "@strait/transactional/registry": [
        "../../packages/transactional/emails/registry.tsx"
      ]
    },
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json",
    "noEmit": true
  },
  "include": ["**/*.ts", "**/*.tsx", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", "output"]
}
