{
  "name": "@strait/app",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite start",
    "preview": "vite preview",
    "biome:lint": "biome lint ./src",
    "biome:format": "biome format --write ./src",
    "biome:write": "biome check --write ./src",
    "biome:fix:unsafe": "biome check --fix --unsafe ./src",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "generate:api": "cd ../../apps/strait && go run ./scripts/dump-openapi docs/openapi.json && cd ../../apps/app && openapi-typescript ../../apps/strait/docs/openapi.json -o ./src/lib/api/schema.d.ts --export-type",
    "typecheck": "tsgo --noEmit",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "run-all": "bun run biome:fix:unsafe && bun run biome:format && bun run biome:write && bun run biome:lint && bun run typecheck",
    "clean": "git clean -xdf .next .turbo node_modules"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.5.6",
    "@hookform/resolvers": "^5.2.2",
