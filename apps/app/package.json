{
  "name": "@strait/app",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "PORT=5173 vite dev --host localhost --port 5173 --strictPort",
    "build": "bun run build:cloudflare",
    "build:node": "STRAIT_APP_TARGET=node vite build",
    "build:cloudflare": "STRAIT_APP_TARGET=cloudflare vite build",
    "build:vercel": "STRAIT_APP_TARGET=vercel vite build",
    "build:migrate": "bun build ./scripts/migrate-image.ts --target node --format esm --outfile .output/migrate.mjs",
    "start": "node .output/server/index.mjs",
    "start:node": "bun run start",
    "preview": "vite preview",
    "deploy": "SENTRY_UPLOAD_SOURCEMAPS=true bun run build:vercel && bun run sentry:upload-sourcemaps",
    "sentry:upload-sourcemaps": "tsx scripts/sentry-sourcemaps.ts",
    "biome:lint": "biome lint ./src ./e2e",
    "biome:format": "biome format --write ./src ./e2e",
    "biome:write": "biome check --write ./src ./e2e",
    "biome:fix:unsafe": "biome check --fix --unsafe ./src ./e2e",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:core": "playwright test --config e2e/playwright.config.ts tests/harness tests/core-dashboard",
    "e2e:core:local": "node scripts/e2e-core-local.mjs",
    "e2e:local:smoke": "node scripts/e2e-core-local.mjs tests/harness tests/dashboard/smoke.spec.ts tests/navigation",
    "e2e:local:regression": "node scripts/e2e-core-local.mjs tests/core-dashboard tests/jobs tests/runs tests/workflows tests/webhooks tests/dlq tests/schedules tests/events-logs",
    "e2e:local:settings": "node scripts/e2e-core-local.mjs tests/settings tests/org tests/projects tests/security",
    "e2e:local:visual": "node scripts/e2e-core-local.mjs tests/dashboard/charts.spec.ts tests/interaction/responsive.spec.ts tests/interaction/theme.spec.ts tests/interaction/a11y-keyboard.spec.ts",
    "e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "generate:api": "cd ../../apps/strait && go run ./scripts/dump-openapi docs/openapi.json && cd ../../apps/app && openapi-typescript ../../apps/strait/docs/openapi.json -o ./src/lib/api/schema.d.ts --export-type",
    "typecheck": "tsgo --noEmit",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "run-all": "bun run biome:fix:unsafe && bun run biome:format && bun run biome:write && bun run biome:lint && bun run typecheck",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:dry": "tsx scripts/migrate.ts --dry",
    "db:migrate:bun": "bun scripts/migrate.ts",
    "clean": "git clean -xdf .output .vercel dist .turbo node_modules"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.22",
    "@better-auth/passkey": "^1.6.22",
    "@hookform/resolvers": "^5.4.0",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@lukemorales/query-key-factory": "^1.3.4",
    "@react-email/render": "^2.0.9",
    "@sentry/tanstackstart-react": "^10.62.0",
    "@strait/billing": "workspace:*",
    "@strait/transactional": "workspace:*",
    "@strait/ui": "0.1.5",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/zod-adapter": "^1.167.0",
    "@types/pg": "^8.20.0",
    "@upstash/redis": "^1.38.0",
    "@xyflow/react": "^12.11.1",
    "better-auth": "1.6.22",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.4",
    "generate-password-ts": "^1.6.5",
    "jose": "^6.2.3",
    "nanoid": "^5.1.16",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "posthog-js": "^1.395.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.16.0",
    "stripe": "^22.3.0",
    "use-sync-external-store": "^1.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.39.2",
    "@playwright/test": "^1.61.1",
    "@rsbuild/core": "^2.1.1",
    "@sentry/cli": "3.6.0",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router-devtools": "1.167.0",
    "@testing-library/react": "^16.3.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260628.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "nitro": "3.0.260610-beta",
    "tsx": "^4.22.4",
    "vite": "8.1.0",
    "vite-plugin-ngrok": "^2.0.1",
    "vitest": "^4.1.9"
  }
}
