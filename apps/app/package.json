{
  "name": "@strait/app",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:node": "BUILD_TARGET=node vite build",
    "start": "wrangler dev",
    "start:node": "node ./scripts/node-server.mjs",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "sentry:upload-sourcemaps": "tsx scripts/sentry-sourcemaps.ts",
    "biome:lint": "biome lint ./src ./e2e",
    "biome:format": "biome format --write ./src ./e2e",
    "biome:write": "biome check --write ./src ./e2e",
    "biome:fix:unsafe": "biome check --fix --unsafe ./src ./e2e",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "generate:api": "cd ../../apps/strait && go run ./scripts/dump-openapi docs/openapi.json && cd ../../apps/app && openapi-typescript ../../apps/strait/docs/openapi.json -o ./src/lib/api/schema.d.ts --export-type",
    "typecheck": "tsgo --noEmit",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "run-all": "bun run biome:fix:unsafe && bun run biome:format && bun run biome:write && bun run biome:lint && bun run typecheck",
    "db:migrate": "node --import tsx --loader ./scripts/cloudflare-shim.mjs scripts/migrate.ts",
    "db:migrate:dry": "node --import tsx --loader ./scripts/cloudflare-shim.mjs scripts/migrate.ts --dry",
    "db:migrate:bun": "bun --preload ./scripts/cloudflare-shim-bun.mjs scripts/migrate.ts",
    "clean": "git clean -xdf dist .turbo node_modules"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.9",
    "@better-auth/passkey": "^1.6.9",
    "@cloudflare/vite-plugin": "^1.35.0",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@lukemorales/query-key-factory": "^1.3.4",
    "@radix-ui/react-icons": "^1.3.2",
    "@react-email/render": "^2.0.8",
    "@sentry/tanstackstart-react": "^10.51.0",
    "@strait/transactional": "workspace:*",
    "@strait/ui": "workspace:*",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "5.100.9",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.63",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/zod-adapter": "^1.166.9",
    "@types/pg": "^8.20.0",
    "@upstash/redis": "^1.37.0",
    "@xyflow/react": "^12.10.2",
    "better-auth": "1.6.9",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "generate-password-ts": "^1.6.5",
    "jose": "^6.2.3",
    "nanoid": "^5.1.11",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "posthog-js": "1.372.8",
    "react": "^19.2.5",
    "react-copy-to-clipboard": "^5.1.1",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "recharts": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.2",
    "stripe": "^22.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260505.1",
    "@playwright/test": "^1.59.1",
    "@rsbuild/core": "^2.0.3",
    "@sentry/cli": "2.58.5",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@tanstack/react-router-devtools": "1.166.13",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260504.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "knip": "^6.11.0",
    "tsx": "^4.21.0",
    "vite": "8.0.10",
    "vite-plugin-ngrok": "^2.0.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
