# Strait App (Frontend)
# Copy this file to apps/app/.env for local dashboard development.
# VITE_* variables are exposed to browser code. Keep secrets in unprefixed
# server-side variables only. See the root .env.example for the full stack.

# App
VITE_BASE_URL=http://localhost:5173
STRAIT_API_URL=http://localhost:8080
VITE_STRAIT_EDITION=cloud

# Auth
AUTH_DATABASE_URL=postgresql://strait:strait@localhost:15432/strait
BETTER_AUTH_URL=http://localhost:5173
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OIDC / OAuth Provider (for MCP token issuance)
# Must match the Go backend's OIDC_ISSUER and OIDC_AUDIENCE values.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_PRIVATE_KEY_PEM=

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_SCALE_MONTHLY_PRICE_ID=
STRIPE_SCALE_YEARLY_PRICE_ID=

# Resend (email)
RESEND_API_KEY=
RESEND_SUPPORT_EMAIL=noreply@example.com

# Sentry (optional)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog (optional)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
