# Strait App (Frontend)
# Copy this file to apps/app/.env for local dashboard development.
# VITE_* variables are exposed to browser code. Keep secrets in unprefixed
# server-side variables only. See the root .env.example for the full stack.

# App
VITE_BASE_URL=http://localhost:5173
STRAIT_API_URL=http://localhost:8080
VITE_STRAIT_EDITION=cloud

# Auth
AUTH_DATABASE_URL=postgresql://strait:strait@localhost:15432/strait
BETTER_AUTH_URL=http://localhost:5173
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OIDC / OAuth Provider (for MCP token issuance)
# Must match the Go backend's OIDC_ISSUER and OIDC_AUDIENCE values.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_PRIVATE_KEY_PEM=
# Public key served at the JWKS endpoint (/api/auth/jwks).
OIDC_PUBLIC_KEY_PEM=

# Stripe (billing)
STRIPE_SECRET_KEY=
# Plan price IDs, read by the subscription checkout flow.
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_SCALE_MONTHLY_PRICE_ID=
STRIPE_SCALE_YEARLY_PRICE_ID=
STRIPE_BUSINESS_MONTHLY_PRICE_ID=
STRIPE_BUSINESS_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_STARTER_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_GROWTH_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_LARGE_YEARLY_PRICE_ID=

# Resend (email)
RESEND_API_KEY=
RESEND_SUPPORT_EMAIL=noreply@example.com
RESEND_FROM_EMAIL=noreply@example.com
INTERNAL_SECRET=local-dev-internal-secret-change-me

# Sentry (optional)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Set truthy to upload source maps during the build (vite.config.ts).
SENTRY_UPLOAD_SOURCEMAPS=

# PostHog (optional)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Upstash Redis (optional KV; falls back to in-memory when unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local development helpers (optional)
# Write outbound emails to a local outbox instead of sending them.
LOCAL_EMAIL_OUTBOX=
LOCAL_EMAIL_OUTBOX_PATH=
# Expose the local dev server through an ngrok tunnel (vite.config.ts).
ENABLE_NGROK=
DISABLE_NGROK=
