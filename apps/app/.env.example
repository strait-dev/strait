# Strait App (Frontend)
# All environment variables are managed via Doppler (project: strait).
#
# For local development, run from the repo root:
#   doppler setup          (select project: strait, config: dev)
#   doppler run -- <cmd>   (injects all env vars into your process)
#
# The frontend-specific variables are prefixed with VITE_ and are
# included in the unified Doppler config alongside backend vars.
# See the root .env.example for the full list.

# App
VITE_BASE_URL=http://localhost:5173

# Auth
AUTH_DATABASE_URL=postgresql://strait:strait@localhost:5432/strait
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OIDC / OAuth Provider (for MCP token issuance)
# Must match the Go backend's OIDC_ISSUER and OIDC_AUDIENCE values.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_PRIVATE_KEY_PEM=

# Polar (billing)
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_WEBHOOK_SECRET=
POLAR_STARTER_MONTHLY_ID=
POLAR_STARTER_YEARLY_ID=
POLAR_PRO_MONTHLY_ID=
POLAR_PRO_YEARLY_ID=

# Resend (email)
RESEND_API_KEY=
RESEND_SUPPORT_EMAIL=noreply@example.com

# Sentry (optional)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog (optional)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
