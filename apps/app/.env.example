# Strait App
# Copy to .env and fill in values.

# App
VITE_BASE_URL=http://localhost:5173

# Auth
AUTH_DATABASE_URL=postgresql://user:password@host:port/database
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Polar (billing)
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_WEBHOOK_SECRET=
POLAR_STARTER_MONTHLY_ID=
POLAR_STARTER_YEARLY_ID=
POLAR_PROFESSIONAL_MONTHLY_ID=
POLAR_PROFESSIONAL_YEARLY_ID=

# Resend (email)
RESEND_API_KEY=
RESEND_SUPPORT_EMAIL=noreply@example.com

# Sentry (optional)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# PostHog (optional)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
