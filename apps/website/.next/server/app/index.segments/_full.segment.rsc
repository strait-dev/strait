1e:T689,{"@context":"https://schema.org","@type":"SoftwareApplication","@id":"https://trystrait.ai/#software","name":"Strait","description":"Strait is a production-grade Go job orchestration platform for engineering teams and AI agents. Queue runs in PostgreSQL with SKIP LOCKED, orchestrate workflow DAGs, and ship reliable background execution without managing a broker.","url":"https://trystrait.ai","applicationCategory":"ProductivityApplication","operatingSystem":"Web","browserRequirements":"Requires Chrome 90+, Firefox 88+, Safari 14+, or Edge 90+","softwareVersion":"2026.1","author":{"@id":"https://trystrait.ai/#organization"},"provider":{"@id":"https://trystrait.ai/#organization"},"offers":[{"@type":"Offer","name":"Personal","price":"19.00","priceCurrency":"USD","priceValidUntil":"2027-03-10T14:55:12.370Z","availability":"https://schema.org/InStock","url":"https://trystrait.ai/pricing","description":"For individual writers and creators."},{"@type":"Offer","name":"Pro","price":"49.00","priceCurrency":"USD","priceValidUntil":"2027-03-10T14:55:12.370Z","availability":"https://schema.org/InStock","url":"https://trystrait.ai/pricing","description":"For teams and power users who need advanced workflows."}],"featureList":["PostgreSQL queue with SKIP LOCKED","13-state run lifecycle management","Workflow DAG orchestration","Step conditions and approval gates","Retry strategies with jitter","Dead letter queue and replay","SDK endpoints for run telemetry","Debug bundles and execution tracing","Cost budget enforcement","API, CLI, and TUI operations"],"screenshot":{"@type":"ImageObject","url":"https://trystrait.ai/opengraph-image.jpg","width":1200,"height":630}}1f:T446,{"@context":"https://schema.org","@type":"HowTo","@id":"https://trystrait.ai/#howto","name":"How to Get Started with Strait","description":"Learn how to get started with Strait job orchestration in three simple steps.","totalTime":"PT10M","estimatedCost":{"@type":"MonetaryAmount","currency":"USD","value":"0"},