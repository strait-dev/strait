---
import { StaticPricingTable } from "@/components/landing-page/pricing/static-pricing-table.tsx";
import Shell from "@/components/layout/shell.tsx";
---

<section id="pricing" class="py-20 sm:py-28">
  <Shell variant="wide">
    <div class="mb-14 max-w-3xl">
      <h2 class="text-balance text-2xl leading-[1.2] sm:text-3xl lg:text-4xl">
        Free to start. Pay as you grow.
      </h2>
      <p class="mt-3 text-pretty text-muted-foreground text-sm leading-relaxed sm:text-base">
        Every plan includes all core features. Upgrade when you need more runs, more compute, or team controls.
      </p>
    </div>

    <div class="mb-8 flex flex-wrap items-center gap-2.5">
      <span class="rounded-full border border-border/60 bg-card px-3 py-1 text-muted-foreground text-sm">
        No credit card required
      </span>
      <span class="rounded-full border border-border/60 bg-card px-3 py-1 text-muted-foreground text-sm">
        14-day trial on paid plans
      </span>
      <span class="rounded-full border border-border/60 bg-card px-3 py-1 text-muted-foreground text-sm">
        Cancel anytime
      </span>
    </div>

    <div class="min-h-[300px]">
      <StaticPricingTable client:only="react" />
    </div>

    <div class="mt-10 flex flex-col items-center gap-3 text-center">
      <p class="max-w-lg text-muted-foreground text-sm">
        All paid plans include compute credits. Additional runs at $0.20 per 1,000.
      </p>
      <a
        class="font-medium text-muted-foreground text-sm transition-colors hover:text-foreground"
        href="/pricing"
      >
        Compare all plans →
      </a>
    </div>
  </Shell>
</section>
