---
import Shell from "@/components/layout/shell.tsx";
import { siteConfig } from "@/config/site.ts";
import { dashboardHref } from "@/lib/urls.ts";
import HeaderDropdown from "./HeaderDropdown.tsx";
import MobileNav from "./HeaderMobileNav.tsx";
import { isNavGroup, NAV_ITEMS } from "./nav-links.ts";
---

<header class="fixed inset-x-0 top-0 z-50 border-border/40 border-b bg-background/5 backdrop-blur-md">
	<Shell variant="wide">
		<nav class="py-3">
			<div class="flex h-12 items-center justify-between">
				<a class="flex items-center space-x-2" href="/">
					<span class="sr-only">{siteConfig.name}</span>
					<img
						alt={siteConfig.logo.alt}
						class="h-8 w-auto"
						height={siteConfig.logo.height}
						src={siteConfig.logo.src}
						width={siteConfig.logo.width}
					/>
				</a>

				<div class="hidden items-center gap-6 lg:flex">
					{NAV_ITEMS.map((item) => {
						if (isNavGroup(item)) {
							return <HeaderDropdown client:load group={item} />;
						}

						return (
							<a
								class="inline-flex h-9 items-center gap-1 rounded-md px-3 font-medium text-foreground/80 text-sm transition-colors hover:text-foreground"
								href={item.href}
							>
								{item.label}
							</a>
						);
					})}
				</div>

				<div class="hidden items-center gap-3 lg:flex">
					<a
						class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 font-medium text-sm shadow-xs transition-colors hover:bg-accent hover:text-accent-foreground"
						href={dashboardHref("/login")}
					>
						Sign in
					</a>
					<a
						class="inline-flex h-9 items-center justify-center gap-2 rounded-md bg-gradient-to-r from-primary to-primary/80 px-4 font-medium text-primary-foreground text-sm shadow-xs transition-shadow duration-300 hover:shadow-md"
						href={dashboardHref("/login")}
					>
						Run your first job
						<svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
							<path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</a>
				</div>

				<div class="lg:hidden">
					<MobileNav client:load />
				</div>
			</div>
		</nav>
	</Shell>
</header>

