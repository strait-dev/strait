---
import Shell from "@/components/layout/shell.tsx";

const PAIN_POINTS = [
  {
    before: "Your retry logic lives in four different places",
    after: "Retries, backoff, and timeouts in one place",
  },
  {
    before: "A tangle of shell scripts connecting your jobs",
    after: "Multi-step workflows with conditions and parallel steps",
  },
  {
    before: "30 minutes digging through logs after a failure",
    after: "A timeline showing every step of every run",
  },
  {
    before: "Every team building their own job system from scratch",
    after: "One platform that works with any language your team uses",
  },
];
---

<section
  aria-label="The problem with background job systems"
  class="infinity-border-y overflow-hidden py-20 sm:py-28"
>
  <Shell variant="wide">
    <div class="mb-14 max-w-3xl">
      <h2 class="text-balance text-2xl leading-[1.2] sm:text-3xl lg:text-4xl">
        Sound familiar?
      </h2>
      <p class="mt-3 text-pretty text-muted-foreground text-sm leading-relaxed sm:text-base">
        Most teams spend weeks building job infrastructure from scratch. Then they spend months maintaining it.
        Strait replaces all of it.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2">
      {PAIN_POINTS.map((point, i) => (
        <div class:list={[
          "p-5 sm:p-6",
          i > 0 && "border-t border-border sm:border-t-0",
          i >= 2 && "sm:border-t sm:border-border",
          i % 2 !== 0 && "sm:border-l sm:border-border",
        ]}>
          <p class="text-muted-foreground/50 text-sm leading-relaxed line-through decoration-destructive/40">
            {point.before}
          </p>
          <p class="mt-2 font-medium text-foreground text-sm leading-relaxed">
            <span class="mr-2 inline-block size-1.5 rounded-full bg-primary" />
            {point.after}
          </p>
        </div>
      ))}
    </div>
  </Shell>
</section>
