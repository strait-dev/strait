---
import type { ComparisonHighlight } from "@/data/comparisons.ts";

type Props = {
  highlights: ComparisonHighlight[];
  competitorName: string;
};

const { highlights, competitorName } = Astro.props;
---

{highlights.length > 0 && (
  <div>
    <div class="mb-10">
      <h2 class="text-2xl sm:text-3xl">What Strait does differently</h2>
      <p class="mt-3 text-pretty text-muted-foreground text-sm leading-relaxed sm:text-base">
        Features where Strait offers a distinct advantage over{" "}
        {competitorName}.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {highlights.map((highlight) => (
        <div>
          <div class="rounded-xl border border-border/40 bg-card/50 p-6">
            <div class="mb-3 flex items-center gap-2">
              <span class="rounded-md bg-primary/10 px-2 py-0.5 font-medium text-primary text-xs">
                Strait
              </span>
            </div>
            <h3 class="font-semibold text-foreground">
              {highlight.title}
            </h3>
            <p class="mt-2 text-muted-foreground text-sm leading-relaxed">
              {highlight.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
)}
