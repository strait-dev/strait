---
interface NavPost {
  slug: string;
  title: string;
}

interface Props {
  nextPost?: NavPost | null;
  prevPost?: NavPost | null;
}

const { prevPost, nextPost } = Astro.props;

if (!(prevPost || nextPost)) {
  return null;
}
---

<nav
	aria-label="Post navigation"
	class="mt-12 grid grid-cols-1 gap-4 border-border border-t pt-8 sm:grid-cols-2"
>
	{prevPost ? (
		<a
			class="group flex items-center gap-3 rounded-2xl border border-border/60 bg-card p-4 transition-all hover:border-border hover:shadow-md"
			href={`/blog/${prevPost.slug}`}
		>
			<svg class="size-5 shrink-0 text-muted-foreground transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
				<path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
			<div class="min-w-0">
				<p class="text-muted-foreground text-xs uppercase tracking-wide">Previous</p>
				<p class="truncate font-medium text-foreground">{prevPost.title}</p>
			</div>
		</a>
	) : (
		<div />
	)}

	{nextPost ? (
		<a
			class="group flex items-center justify-end gap-3 rounded-2xl border border-border/60 bg-card p-4 text-right transition-all hover:border-border hover:shadow-md"
			href={`/blog/${nextPost.slug}`}
		>
			<div class="min-w-0">
				<p class="text-muted-foreground text-xs uppercase tracking-wide">Next</p>
				<p class="truncate font-medium text-foreground">{nextPost.title}</p>
			</div>
			<svg class="size-5 shrink-0 text-muted-foreground transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
				<path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
		</a>
	) : (
		<div />
	)}
</nav>
