---
import PostPreview from "@/components/landing-page/blog/post-preview.tsx";

interface Props {
  posts: any[];
}

const { posts } = Astro.props;

if (posts.length === 0) {
  return null;
}
---

<section class="mt-20 border-border border-t pt-12">
	<h2 class="mb-8 text-2xl text-foreground">Related Articles</h2>
	<div class="overflow-hidden rounded-2xl border border-border/50">
		<div class="grid grid-cols-1 gap-px bg-border/50 md:grid-cols-3">
			{posts.map((post) => (
				<div class="bg-background p-6">
					<PostPreview client:only="react" {...post} />
				</div>
			))}
		</div>
	</div>
</section>
