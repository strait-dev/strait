---
import ComparisonSection from "@/components/ComparisonSection.astro";
import CTA from "@/components/CTA.astro";
import JsonLd from "@/components/JsonLd.astro";
import CredibilitySection from "@/components/landing/credibility-section.tsx";
import FeatureBentoGrid from "@/components/landing/feature-bento-grid.tsx";
import CodeExampleSection from "@/components/landing-page/code-examples/code-example-section.tsx";
import Shell from "@/components/layout/shell.tsx";
import LinkButton from "@/components/common/LinkButton.tsx";
import PricingTeaser from "@/components/PricingTeaser.astro";
import ProblemSection from "@/components/ProblemSection.astro";
import PricingComparison from "@/components/pricing/pricing-comparison.tsx";
import PricingFaq from "@/components/pricing/pricing-faq.tsx";
import SEO from "@/components/SEO.astro";
import LandingLayout from "@/layouts/LandingLayout.astro";
import {
  getHowToSchema,
  getOrganizationSchema,
  getSoftwareApplicationSchema,
  getWebSiteSchema,
} from "@/lib/structured-data.tsx";
import { dashboardHref } from "@/lib/urls.ts";

const HOW_TO_STEPS = [
  {
    title: "Install the SDK and define a job",
    description:
			"Pick your language: TypeScript, Python, Go, Ruby, or Rust. Define what each job does, how many times to retry, and when to time out.",
  },
  {
    title: "Create workflows and trigger runs",
    description:
			"Connect jobs into multi-step workflows with dependencies, conditions, and approval gates. Start runs from your API, SDK, or on a schedule.",
  },
  {
		title: "Monitor, debug, and scale",
    description:
			"See the status of every run in real time. Track costs, spot failures instantly, and scale with managed containers across regions.",
  },
];

const organizationSchema = getOrganizationSchema();
const webSiteSchema = getWebSiteSchema();
const softwareAppSchema = getSoftwareApplicationSchema();
const howToSchema = getHowToSchema(HOW_TO_STEPS);
---

<LandingLayout>
	<Fragment slot="head">
		<SEO
			path="/"
			appendSiteTitle={false}
			keywords={[
				"Go job orchestration",
				"PostgreSQL job queue",
				"workflow DAG engine",
				"background job processing",
				"run retries and dead letter queue",
				"workflow approvals",
				"AI agent orchestration",
				"managed execution",
				"open source job queue",
				"Strait",
			]}
		/>
	</Fragment>
	<JsonLd data={organizationSchema} />
	<JsonLd data={webSiteSchema} />
	<JsonLd data={softwareAppSchema} />
	{howToSchema && <JsonLd data={howToSchema} />}

	<!-- Hero -->
	<section class="relative isolate overflow-hidden pt-32 pb-16 sm:pt-40 sm:pb-24">
		<div class="orchestration-grid pointer-events-none absolute inset-0 -z-10 opacity-50 fade-bottom" />
		<Shell variant="wide">
			<div class="mx-auto flex max-w-4xl flex-col items-center text-center">
				<span class="kicker">BACKGROUND JOBS AND WORKFLOWS, HANDLED</span>

				<h1 class="mt-6 text-balance text-4xl leading-[1.12] sm:text-5xl lg:text-6xl">
					Background jobs, workflows, and
					<span class="text-primary">AI agents</span> that never lose state.
				</h1>
				<p class="mx-auto mt-4 max-w-2xl text-pretty text-muted-foreground text-sm leading-relaxed sm:text-base">
					Run background jobs, orchestrate multi-step workflows, and keep AI agents on budget. Set up in under 5 minutes.
				</p>

				<div class="mt-10 flex flex-col items-center gap-4 sm:flex-row">
					<LinkButton client:load href={dashboardHref("/login")}>
						Run your first job
						<svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
							<path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</LinkButton>
					<LinkButton client:load href="/docs/quickstart" variant="outline">
						<svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
							<path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
						See how it works
					</LinkButton>
				</div>
			</div>
		</Shell>
	</section>

	<ProblemSection />

	<!-- Features (React bento grid with animations) -->
	<div class="section-muted">
		<FeatureBentoGrid client:only="react" />
	</div>

	<!-- Code examples -->
	<div class="min-h-[400px]">
		<CodeExampleSection client:only="react" />
	</div>

	<!-- Credibility: open source, architecture, comparison -->
	<div class="section-muted">
		<CredibilitySection client:only="react" />
	</div>

	<ComparisonSection />

	<!-- Pricing -->
	<PricingTeaser />
	<div class="min-h-[400px]">
		<PricingComparison client:only="react" />
	</div>
	<div class="min-h-[300px]">
		<PricingFaq client:only="react" />
	</div>

	<!-- Final CTA -->
	<CTA />
</LandingLayout>
