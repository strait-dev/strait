---
import CTA from "@/components/CTA.astro";
import JsonLd from "@/components/JsonLd.astro";
import Shell from "@/components/layout/shell.tsx";
import SEO from "@/components/SEO.astro";
import {
  FEATURE_PAGES,
  getAllFeatureSlugs,
  getFeatureBySlug,
} from "@/data/features.ts";
import LandingLayout from "@/layouts/LandingLayout.astro";
import { getBreadcrumbSchema } from "@/lib/structured-data.tsx";
import { dashboardHref } from "@/lib/urls.ts";
import LinkButton from "@/components/common/LinkButton.tsx";

export function getStaticPaths() {
  return getAllFeatureSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const feature = slug ? getFeatureBySlug(slug) : undefined;
if (!feature) {
  return Astro.redirect("/404");
}

const BASE_URL = import.meta.env.PUBLIC_WEBSITE_URL || "https://trystrait.ai";
const breadcrumbs = getBreadcrumbSchema([
  { name: "Home", url: BASE_URL },
  { name: "Features", url: `${BASE_URL}/features` },
  { name: feature.name, url: `${BASE_URL}/features/${feature.slug}` },
]);

const related = feature.relatedSlugs
  .map((s) => FEATURE_PAGES.find((f) => f.slug === s))
  .filter(Boolean);
---

<LandingLayout>
  <Fragment slot="head">
    <SEO
      title={`${feature.name} — Strait Features`}
      description={feature.description}
      path={`/features/${feature.slug}`}
      keywords={[feature.name, "Strait", "job orchestration", "workflow"]}
    />
  </Fragment>
  <JsonLd data={breadcrumbs} />

  <!-- Hero -->
  <section class="relative isolate overflow-hidden pt-32 pb-16 sm:pt-40 sm:pb-20">
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(to_bottom,_transparent,_var(--background)_70%)]" />

    <Shell variant="wide">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-1.5 text-muted-foreground text-sm">
        <a class="transition-colors hover:text-foreground" href="/">Home</a>
        <span>/</span>
        <a class="transition-colors hover:text-foreground" href="/features">Features</a>
        <span>/</span>
        <span class="text-foreground">{feature.name}</span>
      </nav>

      <div class="max-w-3xl">
        <span class="kicker">{feature.name}</span>
        <h1 class="mt-4 text-4xl leading-[1.12] tracking-[-0.025em] sm:text-5xl lg:text-6xl">
          <span class="text-foreground">{feature.headline}</span>{" "}
          <span class="text-muted-foreground">{feature.subheadline}</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-muted-foreground leading-relaxed">
          {feature.description}
        </p>
        <div class="mt-8">
					<LinkButton client:load href={dashboardHref("/login")}>
						Try it now
						<svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
							<path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</LinkButton>
          </a>
        </div>
      </div>
    </Shell>
  </section>

  <!-- Specs Grid -->
  <section class="border-border/40 border-y py-16 sm:py-20">
    <Shell variant="wide">
      <h2 class="mb-10 text-2xl sm:text-3xl">Technical specs</h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {feature.specs.map((spec) => (
          <div>
            <div class="rounded-xl border border-border/60 bg-card p-5">
              <p class="text-muted-foreground text-sm">{spec.label}</p>
              <p class="mt-1 font-medium text-foreground">{spec.value}</p>
            </div>
          </div>
        ))}
      </div>
    </Shell>
  </section>

  <!-- Code Example -->
  <section class="py-16 sm:py-20">
    <Shell variant="wide">
      <h2 class="mb-2 text-2xl sm:text-3xl">{feature.codeExample.title}</h2>
      <div class="mt-8 overflow-hidden rounded-2xl border border-border/60 bg-muted/40">
        <div class="flex items-center justify-between border-border/50 border-b px-4 py-3">
          <div class="flex items-center gap-1.5">
            <span class="size-3 rounded-full bg-[#FF5F57]" />
            <span class="size-3 rounded-full bg-[#FEBC2E]" />
            <span class="size-3 rounded-full bg-[#28C840]" />
            <span class="ml-3 text-muted-foreground/50 text-xs">{`main.${feature.codeExample.language}`}</span>
          </div>
        </div>
        <pre class="overflow-x-auto p-6 font-mono text-sm leading-relaxed">
          <code class="text-foreground/80">{feature.codeExample.code}</code>
        </pre>
      </div>
    </Shell>
  </section>

  <!-- Related Features -->
  {related.length > 0 && (
    <section class="border-border/40 border-t py-16 sm:py-20">
      <Shell variant="wide">
        <h2 class="mb-8 text-2xl sm:text-3xl">Related features</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((r) => r && (
            <div>
              <a
                class="group block rounded-xl border border-border/60 bg-card p-6 transition-shadow hover:shadow-md"
                href={`/features/${r.slug}`}
              >
                <h3 class="font-semibold text-foreground group-hover:text-primary">{r.name}</h3>
                <p class="mt-2 text-muted-foreground text-sm leading-relaxed">{r.subheadline}</p>
              </a>
            </div>
          ))}
        </div>
      </Shell>
    </section>
  )}

  <CTA
    description="Deploy your first workflow in under 10 minutes."
    heading={`Ready to try ${feature.name}?`}
    showInstallSnippet={false}
  />
</LandingLayout>
