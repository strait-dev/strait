---
import Footer from "@/components/common/Footer.astro";
import Header from "@/components/common/Header.astro";
import SEO from "@/components/SEO.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import LinkButton from "@/components/common/LinkButton.tsx";
---

<BaseLayout>
  <Fragment slot="head">
    <SEO
      title="Page Not Found"
      description="The page you're looking for doesn't exist or has been moved."
      path="/404"
      noIndex={true}
    />
  </Fragment>
  <Header />
  <main>
    <div class="flex min-h-[60vh] flex-col items-center justify-center px-4 py-24 text-center">
      <p class="font-mono text-muted-foreground text-sm">404</p>
      <h1 class="mt-4 text-3xl sm:text-4xl">Page not found</h1>
      <p class="mt-4 max-w-md text-muted-foreground leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
        Check the URL, or head back to explore Strait.
      </p>
      <div class="mt-8 flex items-center gap-3">
        <LinkButton client:load href="/">Go home</LinkButton>
        <LinkButton client:load href="/blog" variant="outline">Read the blog</LinkButton>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
