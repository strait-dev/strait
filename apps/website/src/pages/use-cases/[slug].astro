---
import CTA from "@/components/CTA.astro";
import LoadingCarousel from "@/components/cultui/loading-carousel.tsx";
import JsonLd from "@/components/JsonLd.astro";
import Shell from "@/components/layout/shell.tsx";
import SEO from "@/components/SEO.astro";
import { getAllUseCaseSlugs, getUseCaseBySlug } from "@/data/use-cases.ts";
import LandingLayout from "@/layouts/LandingLayout.astro";
import { getBreadcrumbSchema } from "@/lib/structured-data.tsx";
import { dashboardHref } from "@/lib/urls.ts";

export function getStaticPaths() {
  return getAllUseCaseSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const useCase = slug ? getUseCaseBySlug(slug) : undefined;
if (!useCase) {
  return Astro.redirect("/404");
}

const BASE_URL = import.meta.env.PUBLIC_WEBSITE_URL || "https://trystrait.ai";
const breadcrumbs = getBreadcrumbSchema([
  { name: "Home", url: BASE_URL },
  { name: "Use Cases", url: `${BASE_URL}/use-cases` },
  { name: useCase.title, url: `${BASE_URL}/use-cases/${useCase.slug}` },
]);
---

<LandingLayout>
  <Fragment slot="head">
    <SEO
      title={`${useCase.title} — Strait Use Cases`}
      description={useCase.solution}
      path={`/use-cases/${useCase.slug}`}
      keywords={[useCase.title, "Strait", "job orchestration", "use case"]}
    />
  </Fragment>
  <JsonLd data={breadcrumbs} />

  <!-- Hero -->
  <section class="relative isolate overflow-hidden pt-32 pb-16 sm:pt-40 sm:pb-20">
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(to_bottom,_transparent,_var(--background)_70%)]" />

    <Shell variant="wide">
      <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-1.5 text-muted-foreground text-sm">
        <a class="transition-colors hover:text-foreground" href="/">Home</a>
        <span>/</span>
        <a class="transition-colors hover:text-foreground" href="/use-cases">Use Cases</a>
        <span>/</span>
        <span class="text-foreground">{useCase.title}</span>
      </nav>

      <div class="max-w-3xl">
        <span class="kicker">{useCase.title}</span>
        <h1 class="mt-4 text-4xl leading-[1.12] tracking-[-0.025em] sm:text-5xl lg:text-6xl">
          <span class="text-foreground">{useCase.headline}</span>
        </h1>

        <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
          <div class="rounded-xl border border-border/60 bg-card p-6">
            <p class="font-medium text-foreground text-sm uppercase tracking-wider">The Problem</p>
            <p class="mt-3 text-muted-foreground leading-relaxed">{useCase.problem}</p>
          </div>
          <div class="rounded-xl border border-primary/30 bg-primary/5 p-6">
            <p class="font-medium text-primary text-sm uppercase tracking-wider">The Solution</p>
            <p class="mt-3 text-muted-foreground leading-relaxed">{useCase.solution}</p>
          </div>
        </div>

        <div class="mt-8">
          <a
            class="inline-flex h-9 items-center justify-center gap-2 rounded-md bg-primary px-4 font-medium text-primary-foreground text-sm"
            href={dashboardHref("/login")}
          >
            Get started
            <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </Shell>
  </section>

  <!-- Workflow Diagram -->
  <section class="border-border/40 border-y py-16 sm:py-20">
    <Shell variant="wide">
      <h2 class="mb-10 text-2xl sm:text-3xl">How it works</h2>
      <LoadingCarousel
        client:only="react"
        autoplayDelay={4000}
        slides={useCase.workflowSteps.map((step, index) => ({
          number: index + 1,
          name: step.name,
          description: step.description,
        }))}
      />
    </Shell>
  </section>

  <!-- Relevant Features -->
  <section class="py-16 sm:py-20">
    <Shell variant="wide">
      <h2 class="mb-8 text-2xl sm:text-3xl">Relevant features</h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {useCase.relevantFeatures.map((feature) => (
          <div>
            <a
              class="group block rounded-xl border border-border/60 bg-card p-6 transition-shadow hover:shadow-md"
              href={`/features/${feature.slug}`}
            >
              <h3 class="font-semibold text-foreground group-hover:text-primary">{feature.name}</h3>
              <p class="mt-2 text-muted-foreground text-sm leading-relaxed">{feature.description}</p>
            </a>
          </div>
        ))}
      </div>
    </Shell>
  </section>

  <CTA
    description="Deploy your first workflow in under 10 minutes."
    heading={`Ready to build ${useCase.title.toLowerCase()}?`}
    showInstallSnippet={false}
  />
</LandingLayout>
