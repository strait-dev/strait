---
import { basehub } from "basehub";
import Pagination from "@/components/landing-page/blog/pagination.tsx";
import { PostFragment as PostFragmentQuery } from "@/components/landing-page/blog/post.tsx";
import PostFeatured from "@/components/landing-page/blog/post-featured.tsx";
import PostPreview from "@/components/landing-page/blog/post-preview.tsx";
import CTA from "@/components/landing-page/common/cta/cta.tsx";
import Shell from "@/components/layout/shell.tsx";
import SEO from "@/components/SEO.astro";
import LandingLayout from "@/layouts/LandingLayout.astro";

const POSTS_PER_PAGE = 8;

export async function getStaticPaths() {
	let totalCount = 0;
	try {
		const countData = await basehub({ token: process.env.BASEHUB_TOKEN || import.meta.env.BASEHUB_TOKEN, cache: "no-store" }).query({
			website: { blog: { posts: { _meta: { totalCount: true } } } },
		});
		totalCount = (countData as any).website.blog.posts._meta.totalCount;
	} catch {
		return [];
	}

	const totalPages = Math.ceil(totalCount / 8);
	if (totalPages <= 1) { return []; }

	return Array.from({ length: totalPages - 1 }, (_, i) => ({
		params: { page: String(i + 2) },
		props: { totalPages },
	}));
}

const { totalPages } = Astro.props as { totalPages: number };
const { page: pageParam } = Astro.params;
const currentPage = Number(pageParam);

if (currentPage === 1) {
	return Astro.redirect("/blog");
}

const skip = (currentPage - 1) * POSTS_PER_PAGE;
let posts: any[] = [];

try {
	const data = await basehub({ token: process.env.BASEHUB_TOKEN || import.meta.env.BASEHUB_TOKEN }).query({
		website: {
			blog: {
				posts: {
					__args: {
						orderBy: "publishedAt__DESC",
						first: POSTS_PER_PAGE,
						skip,
					},
					items: PostFragmentQuery,
				},
			},
		},
	});
	posts = (data as any).website.blog.posts.items;
} catch {
	// Basehub unavailable
}

const featuredPost = posts.length > 0 ? posts[0] : null;
const remainingPosts = featuredPost ? posts.slice(1) : posts;
---

<LandingLayout>
	<Fragment slot="head">
		<SEO
			title={`Blog - Page ${currentPage}`}
			description="Product updates, engineering deep dives, and best practices for background jobs, workflows, and AI agents."
			path={`/blog/page/${currentPage}`}
		/>
	</Fragment>
	<main class="flex flex-col">
		<section class="relative isolate overflow-hidden pt-32 pb-12 sm:pt-40 sm:pb-16">
			<div class="absolute inset-0 -z-10 bg-[linear-gradient(to_bottom,_var(--primary)/0.06,_transparent_40%)]" />
			<div class="absolute inset-0 -z-10 bg-[linear-gradient(to_bottom,_transparent,_var(--background)_70%)]" />

			<Shell variant="wide">
				<div class="mx-auto flex max-w-3xl flex-col items-center text-center">
					<span class="kicker">Blog</span>
					<h1 class="mt-6 text-balance text-4xl leading-[1.15] sm:text-5xl">
						Page {currentPage}
					</h1>
				</div>
			</Shell>
		</section>

		{posts.length === 0 ? (
			<section class="py-20 sm:py-28">
				<Shell variant="wide">
					<p class="text-center text-lg text-muted-foreground">
						No more posts.
					</p>
				</Shell>
			</section>
		) : (
			<section class="pb-20 sm:pb-28">
				<Shell variant="wide">
					{featuredPost && (
						<div class="pb-8">
							<PostFeatured client:only="react" {...featuredPost} />
						</div>
					)}

					{remainingPosts.length > 0 && (
						<div class="overflow-hidden rounded-2xl border border-border/50">
							<div class="grid grid-cols-1 gap-px bg-border/50 md:grid-cols-2">
								{remainingPosts.map((post: any) => (
									<div class="bg-background p-6">
										<PostPreview client:only="react" {...post} />
									</div>
								))}
							</div>
						</div>
					)}

					{totalPages > 1 && (
						<div class="mt-8">
							<Pagination
								client:only="react"
								currentPage={currentPage}
								totalPages={totalPages}
								basePath="/blog"
							/>
						</div>
					)}
				</Shell>
			</section>
		)}

		<CTA client:only="react" />
	</main>
</LandingLayout>
