---
import { basehub } from "basehub";
import LandingLayout from "@/layouts/LandingLayout.astro";
import SEO from "@/components/SEO.astro";
import JsonLd from "@/components/JsonLd.astro";
import Shell from "@/components/layout/shell.tsx";
import CTA from "@/components/landing-page/common/cta/cta.tsx";
import PostFeatured from "@/components/landing-page/blog/post-featured.tsx";
import PostPreview from "@/components/landing-page/blog/post-preview.tsx";
import { PostFragment as PostFragmentQuery } from "@/components/landing-page/blog/post.tsx";
import {
  getBreadcrumbSchema,
  getCollectionPageSchema,
} from "@/lib/structured-data.tsx";

const BASE_URL = import.meta.env.PUBLIC_WEBSITE_URL || "https://trystrait.ai";
const POSTS_PER_PAGE = 8;

let posts: any[] = [];
let totalCount = 0;

try {
  const data = await basehub().query({
    website: {
      blog: {
        posts: {
          __args: {
            orderBy: "publishedAt__DESC",
            first: POSTS_PER_PAGE,
          },
          items: PostFragmentQuery,
          _meta: {
            totalCount: true,
          },
        },
      },
    },
  });
  posts = (data as any).website.blog.posts.items;
  totalCount = (data as any).website.blog.posts._meta.totalCount;
} catch (e) {
  // If basehub fails, continue with empty posts
}

const blogUrl = `${BASE_URL}/blog`;
const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Home", url: BASE_URL },
  { name: "Blog", url: blogUrl },
]);
const collectionSchema = getCollectionPageSchema({
  name: "Strait Blog",
  description: "Tips, insights, and ideas on AI-powered writing and productivity.",
  url: blogUrl,
});

const featuredPost = posts.length > 0 ? posts[0] : null;
const remainingPosts = posts.length > 1 ? posts.slice(1) : [];
const totalPages = Math.ceil(totalCount / POSTS_PER_PAGE);
---

<LandingLayout>
  <Fragment slot="head">
    <SEO
      title="Blog"
      description="Tips, insights, and best practices for job orchestration, workflow automation, and background processing."
      path="/blog"
    />
  </Fragment>
  <main class="flex flex-col">
    <JsonLd data={breadcrumbSchema} />
    <JsonLd data={collectionSchema} />

    <section class="relative isolate overflow-hidden pt-32 pb-12 sm:pt-40 sm:pb-16">
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(to_bottom,_var(--primary)/0.06,_transparent_40%)]" />
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(to_bottom,_transparent,_var(--background)_70%)]" />
      <Shell variant="wide">
        <div class="mx-auto max-w-3xl text-center">
          <span class="kicker">Blog</span>
          <h1 class="mt-4 text-balance text-4xl leading-[1.12] sm:text-5xl lg:text-6xl">
            Insights for builders
          </h1>
          <p class="mt-4 text-pretty text-muted-foreground leading-relaxed">
            Engineering deep dives, best practices, and updates from the Strait team.
          </p>
        </div>
      </Shell>
    </section>

    {posts.length === 0 ? (
      <section class="py-20 sm:py-28">
        <Shell variant="wide">
          <p class="text-center text-lg text-muted-foreground">
            No posts found. Check back soon!
          </p>
        </Shell>
      </section>
    ) : (
      <section class="pb-20 sm:pb-28">
        <Shell variant="wide">
          {featuredPost && (
            <div class="pb-8">
              <PostFeatured client:load {...featuredPost} />
            </div>
          )}

          {remainingPosts.length > 0 && (
            <div class="overflow-hidden rounded-2xl border border-border/50">
              <div class="grid grid-cols-1 gap-px bg-border/50 md:grid-cols-2">
                {remainingPosts.map((post: any) => (
                  <div class="bg-background p-6">
                    <PostPreview client:load {...post} />
                  </div>
                ))}
              </div>

              {totalPages > 1 && (
                <div class="border-border/50 border-t bg-background py-8 text-center">
                  <a href="/blog/page/2" class="text-primary text-sm hover:underline">
                    Next page &rarr;
                  </a>
                </div>
              )}
            </div>
          )}
        </Shell>
      </section>
    )}

    <CTA client:visible />
  </main>
</LandingLayout>
