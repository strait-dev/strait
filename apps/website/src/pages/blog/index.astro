---
import { basehub } from "basehub";
import JsonLd from "@/components/JsonLd.astro";
import Pagination from "@/components/landing-page/blog/pagination.tsx";
import { PostFragment as PostFragmentQuery } from "@/components/landing-page/blog/post.tsx";
import PostFeatured from "@/components/landing-page/blog/post-featured.tsx";
import PostPreview from "@/components/landing-page/blog/post-preview.tsx";
import CTA from "@/components/landing-page/common/cta/cta.tsx";
import Shell from "@/components/layout/shell.tsx";
import SEO from "@/components/SEO.astro";
import LandingLayout from "@/layouts/LandingLayout.astro";
import {
  getBreadcrumbSchema,
  getCollectionPageSchema,
} from "@/lib/structured-data.tsx";

const BASE_URL = import.meta.env.PUBLIC_WEBSITE_URL || "https://strait.dev";
const POSTS_PER_PAGE = 8;

let posts: any[] = [];
let totalCount = 0;

// Fetch blog hero data
let heroTitle = "Engineering the future of job orchestration.";
let heroSubtitle =
  "Product updates, engineering deep dives, and best practices for background jobs, workflows, and AI agents.";
let heroBadge = "Our Blog";

try {
  const data = await basehub({ token: process.env.BASEHUB_TOKEN || import.meta.env.BASEHUB_TOKEN }).query({
    website: {
      blog: {
        hero: {
          hero: {
            title: true,
            subtitle: true,
            badge: true,
          },
        },
        posts: {
          __args: {
            orderBy: "publishedAt__DESC",
            first: POSTS_PER_PAGE,
          },
          items: PostFragmentQuery,
          _meta: {
            totalCount: true,
          },
        },
      },
    },
  });
  const result = data as any;
  posts = result.website.blog.posts.items;
  totalCount = result.website.blog.posts._meta.totalCount;

  if (result.website.blog.hero?.hero) {
    const h = result.website.blog.hero.hero;
    if (h.title) {
      heroTitle = h.title;
    }
    if (h.subtitle) {
      heroSubtitle = h.subtitle;
    }
    if (h.badge) {
      heroBadge = h.badge;
    }
  }
} catch {
  // Basehub unavailable
}

const totalPages = Math.ceil(totalCount / POSTS_PER_PAGE);
const featuredPost = posts.length > 0 ? posts[0] : null;
const remainingPosts = posts.length > 1 ? posts.slice(1) : [];

const blogUrl = `${BASE_URL}/blog`;
const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Home", url: BASE_URL },
  { name: "Blog", url: blogUrl },
]);
const collectionSchema = getCollectionPageSchema({
  name: "Strait Blog",
  description: heroSubtitle,
  url: blogUrl,
});
---

<LandingLayout>
	<Fragment slot="head">
		<SEO
			title="Blog"
			description={heroSubtitle}
			path="/blog"
		/>
	</Fragment>
	<main class="flex flex-col">
		<JsonLd data={breadcrumbSchema} />
		<JsonLd data={collectionSchema} />

		<!-- Blog Hero (inline) -->
		<section class="relative isolate overflow-hidden pt-32 pb-12 sm:pt-40 sm:pb-16">
			<div class="absolute inset-0 -z-10 bg-[linear-gradient(to_bottom,_var(--primary)/0.06,_transparent_40%)]" />
			<div class="absolute inset-0 -z-10 bg-[linear-gradient(to_bottom,_transparent,_var(--background)_70%)]" />
			<div class="paper-texture absolute inset-0 -z-10 opacity-[0.02]" />

			<Shell variant="wide">
				<div class="mx-auto flex max-w-3xl flex-col items-center text-center">
					<span class="kicker">{heroBadge}</span>
					<h1 class="mt-6 text-balance text-4xl leading-[1.15] sm:text-5xl lg:text-6xl">
						<span class="text-foreground">{heroTitle}</span>
					</h1>
					<p class="mt-4 max-w-2xl text-pretty text-muted-foreground leading-relaxed">
						{heroSubtitle}
					</p>
				</div>
			</Shell>
		</section>

		{posts.length === 0 ? (
			<section class="py-20 sm:py-28">
				<Shell variant="wide">
					<p class="text-center text-lg text-muted-foreground">
						No posts found. Check back soon!
					</p>
				</Shell>
			</section>
		) : (
			<section class="pb-20 sm:pb-28">
				<Shell variant="wide">
					{featuredPost && (
						<div class="pb-8">
							<PostFeatured client:only="react" {...featuredPost} />
						</div>
					)}

					{remainingPosts.length > 0 && (
						<div class="overflow-hidden rounded-2xl border border-border/50">
							<div class="grid grid-cols-1 gap-px bg-border/50 md:grid-cols-2">
								{remainingPosts.map((post: any) => (
									<div class="bg-background p-6">
										<PostPreview client:only="react" {...post} />
									</div>
								))}
							</div>

							{totalPages > 1 && (
								<div class="border-border/50 border-t bg-background py-8">
									<Pagination
										client:only="react"
										currentPage={1}
										totalPages={totalPages}
										basePath="/blog"
									/>
								</div>
							)}
						</div>
					)}
				</Shell>
			</section>
		)}

		<CTA client:only="react" />
	</main>
</LandingLayout>
