{
  "groups": [
    {
      "name": "strait-critical",
      "interval": "1m",
      "rules": [
        {
          "alert": "NodeNotReady",
          "expr": "kube_node_status_condition{condition=\"Ready\",status=\"true\"} == 0",
          "for": "5m",
          "labels": { "severity": "critical" },
          "annotations": {
            "summary": "Node {{ $labels.node }} is not ready",
            "runbook": "RUNBOOK.md #1 — restart k3s or rebuild via Terraform"
          }
        },
        {
          "alert": "K3sProcessDown",
          "expr": "up{job=\"node-exporter\"} == 0",
          "for": "3m",
          "labels": { "severity": "critical" },
          "annotations": {
            "summary": "Node {{ $labels.instance }} is unreachable",
            "runbook": "RUNBOOK.md #2 — check Hetzner console, SSH into node"
          }
        },
        {
          "alert": "StraitDown",
          "expr": "up{job=\"strait\"} == 0",
          "for": "2m",
          "labels": { "severity": "critical" },
          "annotations": {
            "summary": "Strait API is unreachable",
            "runbook": "Check pod status: kubectl -n strait get pods"
          }
        }
      ]
    },
    {
      "name": "strait-warning",
      "interval": "1m",
      "rules": [
        {
          "alert": "NodeDiskPressure",
          "expr": "(node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) < 0.15",
          "for": "10m",
          "labels": { "severity": "warning" },
          "annotations": {
            "summary": "Node {{ $labels.instance }} disk usage > 85%",
            "runbook": "RUNBOOK.md #4 — clean images, logs, completed pods"
          }
        },
        {
          "alert": "NodeMemoryPressure",
          "expr": "(node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) < 0.10",
          "for": "5m",
          "labels": { "severity": "warning" },
          "annotations": {
            "summary": "Node {{ $labels.instance }} memory available < 10%",
            "runbook": "Check for memory leaks, consider larger nodes"
          }
        },
        {
          "alert": "JobFailureSpike",
          "expr": "increase(kube_job_status_failed{namespace=\"default\"}[5m]) > 10",
          "for": "0m",
          "labels": { "severity": "warning" },
          "annotations": {
            "summary": "More than 10 job failures in 5 minutes",
            "runbook": "Check job logs: kubectl logs job/<name> -n default"
          }
        },
        {
          "alert": "PodCrashLoop",
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=~\"default|strait\"}[15m]) > 5",
          "for": "0m",
          "labels": { "severity": "warning" },
          "annotations": {
            "summary": "Pod {{ $labels.pod }} has restarted {{ $value }} times in 15m",
            "runbook": "Check pod events: kubectl describe pod {{ $labels.pod }} -n {{ $labels.namespace }}"
          }
        },
        {
          "alert": "PodOOMKill",
          "expr": "kube_pod_container_status_last_terminated_reason{reason=\"OOMKilled\"} > 0",
          "for": "0m",
          "labels": { "severity": "warning" },
          "annotations": {
            "summary": "Pod {{ $labels.pod }} was OOM killed",
            "runbook": "RUNBOOK.md #6 — increase memory limit or upgrade preset"
          }
        },
        {
          "alert": "EtcdBackupStale",
          "expr": "time() - kube_job_status_completion_time{job_name=~\"etcd-backup.*\"} > 43200",
          "for": "0m",
          "labels": { "severity": "warning" },
          "annotations": {
            "summary": "No successful etcd backup in 12 hours",
            "runbook": "RUNBOOK.md #7 — check etcd-backup timer, S3 credentials"
          }
        }
      ]
    },
    {
      "name": "strait-security",
      "interval": "1m",
      "rules": [
        {
          "alert": "KyvernoPolicyViolation",
          "expr": "increase(kyverno_policy_results_total{rule_result=\"fail\",rule_execution_cause=\"admission\"}[5m]) > 0",
          "for": "0m",
          "labels": { "severity": "warning" },
          "annotations": {
            "summary": "Kyverno blocked admission for policy {{ $labels.policy_name }}",
            "runbook": "Check Kyverno logs: kubectl logs -n kyverno -l app=kyverno"
          }
        },
        {
          "alert": "FalcoSecurityAlert",
          "expr": "increase(falco_events{priority=~\"WARNING|CRITICAL\"}[5m]) > 0",
          "for": "0m",
          "labels": { "severity": "critical" },
          "annotations": {
            "summary": "Falco detected suspicious activity",
            "runbook": "Check Falco logs: kubectl logs -n falco -l app=falco"
          }
        }
      ]
    }
  ]
}
