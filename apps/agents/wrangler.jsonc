{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "strait-agents-runtime",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-03-29",
  "observability": {
    "enabled": true
  },
  "worker_loaders": [
    {
      "binding": "SANDBOX_LOADER"
    }
  ],
  "vars": {
    "STRAIT_ENV": "local"
  }
}
