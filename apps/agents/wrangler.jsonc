{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "strait-agents-runtime",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-03-29",
  "observability": {
    "enabled": true
  },
  "worker_loaders": [
    {
      "binding": "SANDBOX_LOADER"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "AGENT_MEMORY",
        "class_name": "AgentMemoryDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["AgentMemoryDO"]
    }
  ],
  "vars": {
    "STRAIT_ENV": "local"
  }
}
