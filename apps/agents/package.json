{
  "name": "@strait/agents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "bun run build:runtime && bun run build:dispatch",
    "build:dispatch": "wrangler deploy --dry-run --config wrangler.dispatch.jsonc --outdir dist/dispatch",
    "build:runtime": "wrangler deploy --dry-run --config wrangler.jsonc --outdir dist/runtime",
    "dev:worker": "wrangler dev --config wrangler.jsonc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "biome:lint": "biome lint ./src",
    "biome:format": "biome format --write ./src",
    "biome:write": "biome check --write ./src",
    "biome:fix:unsafe": "biome check --fix --unsafe ./src",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260327.2",
    "fast-check": "^3.23.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  },
  "dependencies": {
    "effect": "3.21.0"
  }
}
