{
  "name": "@strait/agents-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "bun run build:runtime && bun run build:dispatch && bun run build:outbound",
    "build:dispatch": "wrangler deploy --dry-run --config wrangler.dispatch.jsonc --outdir dist/dispatch",
    "build:outbound": "wrangler deploy --dry-run --config wrangler.outbound.jsonc --outdir dist/outbound",
    "build:runtime": "wrangler deploy --dry-run --config wrangler.jsonc --outdir dist/runtime",
    "deploy:dispatch": "wrangler deploy --config wrangler.dispatch.jsonc",
    "deploy:outbound": "wrangler deploy --config wrangler.outbound.jsonc",
    "deploy:runtime": "wrangler deploy --config wrangler.jsonc",
    "dev:worker": "wrangler dev --config wrangler.jsonc",
    "smoke:cloudflare": "bash ./scripts/cloudflare-smoke.sh",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "biome:lint": "biome lint ./src",
    "biome:format": "biome format --write ./src",
    "biome:write": "biome check --write ./src",
    "biome:fix:unsafe": "biome check --fix --unsafe ./src",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260409.1",
    "fast-check": "^4.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.0"
  },
  "dependencies": {
    "effect": "3.21.0"
  }
}
