{
  "dashboard": {
    "uid": "strait-code-deployments",
    "title": "Strait — Code Deployments",
    "description": "Build pipeline observability: tarball uploads, BuildKit builds, ECR pushes, queue depth, GC, and duration percentiles.",
    "tags": ["strait", "code-deployments", "build"],
    "schemaVersion": 39,
    "version": 1,
    "refresh": "30s",
    "time": { "from": "now-3h", "to": "now" },
    "timepicker": {},
    "templating": {
      "list": [
        {
          "name": "interval",
          "type": "interval",
          "label": "Interval",
          "options": [
            { "selected": false, "text": "1m", "value": "1m" },
            { "selected": false, "text": "5m", "value": "5m" },
            { "selected": true,  "text": "10m", "value": "10m" },
            { "selected": false, "text": "30m", "value": "30m" },
            { "selected": false, "text": "1h", "value": "1h" }
          ],
          "current": { "text": "10m", "value": "10m" },
          "hide": 0
        }
      ]
    },
    "panels": [
      {
        "title": "Row: KPIs",
        "type": "row",
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
      },
      {
        "title": "Build Success Rate",
        "description": "Percentage of builds that reached ready status in the selected interval.",
        "type": "stat",
        "gridPos": { "h": 4, "w": 5, "x": 0, "y": 1 },
        "options": {
          "colorMode": "background",
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent"
        },
        "targets": [
          {
            "expr": "100 * rate(strait_code_deploy_total_total{status=\"ready\"}[$interval]) / (rate(strait_code_deploy_total_total[$interval]) + 0.001)",
            "legendFormat": "Success %"
          }
        ]
      },
      {
        "title": "Active Builds",
        "description": "Builds currently in progress across all orchestrator replicas.",
        "type": "stat",
        "gridPos": { "h": 4, "w": 3, "x": 5, "y": 1 },
        "targets": [
          {
            "expr": "strait_code_deploy_active",
            "legendFormat": "Active"
          }
        ]
      },
      {
        "title": "Queue Depth",
        "description": "Number of building deployments waiting to be claimed by an orchestrator worker.",
        "type": "stat",
        "gridPos": { "h": 4, "w": 3, "x": 8, "y": 1 },
        "targets": [
          {
            "expr": "strait_code_deploy_queue_depth",
            "legendFormat": "Queued"
          }
        ]
      },
      {
        "title": "Throughput (builds/hr)",
        "description": "Total build completions (any status) extrapolated to builds per hour.",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 11, "y": 1 },
        "targets": [
          {
            "expr": "sum(rate(strait_code_deploy_total_total[$interval])) * 3600",
            "legendFormat": "Builds/hr"
          }
        ]
      },
      {
        "title": "P50 Build Duration",
        "description": "Median end-to-end build duration including store update.",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 15, "y": 1 },
        "options": { "unit": "s" },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(strait_code_deploy_duration_seconds_bucket[$interval]))",
            "legendFormat": "P50"
          }
        ]
      },
      {
        "title": "P99 Build Duration",
        "description": "99th percentile end-to-end build duration.",
        "type": "stat",
        "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
        "options": { "unit": "s" },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(strait_code_deploy_duration_seconds_bucket[$interval]))",
            "legendFormat": "P99"
          }
        ]
      },
      {
        "title": "Row: Duration Trends",
        "type": "row",
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
      },
      {
        "title": "End-to-End Build Duration Percentiles",
        "description": "P50, P90, and P99 of total time from orchestrator claim through store update.",
        "type": "timeseries",
        "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
        "options": { "unit": "s" },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(strait_code_deploy_duration_seconds_bucket[$interval])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.90, sum(rate(strait_code_deploy_duration_seconds_bucket[$interval])) by (le))",
            "legendFormat": "P90"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(strait_code_deploy_duration_seconds_bucket[$interval])) by (le))",
            "legendFormat": "P99"
          }
        ]
      },
      {
        "title": "BuildKit-Only Duration Percentiles",
        "description": "P50 and P99 of just the BuildKit build phase (tarball fetch + image build + ECR push), excluding store overhead.",
        "type": "timeseries",
        "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
        "options": { "unit": "s" },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(strait_code_deploy_build_duration_seconds_bucket[$interval])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.90, sum(rate(strait_code_deploy_build_duration_seconds_bucket[$interval])) by (le))",
            "legendFormat": "P90"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(strait_code_deploy_build_duration_seconds_bucket[$interval])) by (le))",
            "legendFormat": "P99"
          }
        ]
      },
      {
        "title": "Row: Throughput & Failures",
        "type": "row",
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
      },
      {
        "title": "Build Throughput by Status",
        "description": "Rate of build completions split by terminal status: ready, failed, timed_out.",
        "type": "timeseries",
        "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
        "targets": [
          {
            "expr": "sum(rate(strait_code_deploy_total_total[$interval])) by (status)",
            "legendFormat": "{{status}}"
          }
        ]
      },
      {
        "title": "Queue Depth Over Time",
        "description": "Building deployments waiting to be claimed, sampled each orchestrator dispatch cycle.",
        "type": "timeseries",
        "gridPos": { "h": 7, "w": 6, "x": 12, "y": 14 },
        "targets": [
          {
            "expr": "strait_code_deploy_queue_depth",
            "legendFormat": "Queue Depth"
          }
        ]
      },
      {
        "title": "Active Builds Over Time",
        "description": "Concurrent builds in-flight across all orchestrator workers.",
        "type": "timeseries",
        "gridPos": { "h": 7, "w": 6, "x": 18, "y": 14 },
        "targets": [
          {
            "expr": "strait_code_deploy_active",
            "legendFormat": "Active Builds"
          }
        ]
      },
      {
        "title": "Row: By Runtime & Tarball",
        "type": "row",
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }
      },
      {
        "title": "P50 Build Duration by Runtime",
        "description": "Median end-to-end build duration broken down by runtime type.",
        "type": "timeseries",
        "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
        "options": { "unit": "s" },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(strait_code_deploy_duration_seconds_bucket[$interval])) by (le, runtime))",
            "legendFormat": "{{runtime}} P50"
          }
        ]
      },
      {
        "title": "Tarball Size Distribution",
        "description": "P50 and P95 of source tarball sizes uploaded by clients before build.",
        "type": "timeseries",
        "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
        "options": { "unit": "bytes" },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(strait_code_deploy_tarball_bytes_bucket[$interval])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(strait_code_deploy_tarball_bytes_bucket[$interval])) by (le))",
            "legendFormat": "P95"
          }
        ]
      },
      {
        "title": "Row: GC & Housekeeping",
        "type": "row",
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 }
      },
      {
        "title": "GC Deployments Collected/hr",
        "description": "Expired pending and failed deployments deleted by the GC worker per hour.",
        "type": "stat",
        "gridPos": { "h": 6, "w": 8, "x": 0, "y": 30 },
        "targets": [
          {
            "expr": "increase(strait_code_deploy_gc_collected_total[$interval])",
            "legendFormat": "Collected"
          }
        ]
      },
      {
        "title": "Total Builds (all time)",
        "description": "Cumulative count of all builds dispatched by the orchestrator.",
        "type": "stat",
        "gridPos": { "h": 6, "w": 8, "x": 8, "y": 30 },
        "targets": [
          {
            "expr": "sum(strait_code_deploy_total_total)",
            "legendFormat": "Total"
          }
        ]
      },
      {
        "title": "Failed Build Rate",
        "description": "Rate of failed + timed_out builds over the selected interval.",
        "type": "stat",
        "gridPos": { "h": 6, "w": 8, "x": 16, "y": 30 },
        "options": {
          "colorMode": "background",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "targets": [
          {
            "expr": "rate(strait_code_deploy_total_total{status=\"failed\"}[$interval]) + rate(strait_code_deploy_total_total{status=\"timed_out\"}[$interval])",
            "legendFormat": "Failures/s"
          }
        ]
      }
    ]
  }
}
