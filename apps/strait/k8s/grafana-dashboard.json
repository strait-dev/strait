{
  "dashboard": {
    "title": "Strait K8s Compute",
    "uid": "strait-k8s-compute",
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "Job Create Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(strait_k8s_job_create_total[5m])) by (status)",
            "legendFormat": "{{status}}"
          }
        ]
      },
      {
        "title": "Pod Scheduling Latency (Cold Start)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.5, sum(rate(strait_k8s_pod_scheduling_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(strait_k8s_pod_scheduling_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "title": "Active Jobs",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "strait_k8s_jobs_active",
            "legendFormat": "active"
          }
        ]
      },
      {
        "title": "Wait Duration P50/P99",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "histogram_quantile(0.5, sum(rate(strait_k8s_job_wait_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(strait_k8s_job_wait_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(strait_k8s_job_create_total{status=\"error\"}[5m]))",
            "legendFormat": "create errors"
          }
        ]
      },
      {
        "title": "Fallback Rate",
        "type": "timeseries",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(strait_compute_fallback_total[5m]))",
            "legendFormat": "fallbacks/sec"
          }
        ]
      },
      {
        "title": "Create Duration by Preset",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(strait_k8s_job_create_duration_seconds_bucket[5m])) by (le, preset))",
            "legendFormat": "p99 {{preset}}"
          }
        ]
      }
    ]
  }
}
