{
  "dashboard": {
    "uid": "strait-api-ingress",
    "title": "Strait - API Ingress",
    "description": "HTTP ingress latency, saturation, and route-level request volume from the Prometheus exporter.",
    "tags": ["strait", "api", "http"],
    "schemaVersion": 39,
    "version": 1,
    "refresh": "30s",
    "time": { "from": "now-6h", "to": "now" },
    "panels": [
      {
        "title": "Request rate by route",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "refId": "A",
            "expr": "sum by (method, route) (rate(strait_http_request_duration_seconds_count[5m]))",
            "legendFormat": "{{method}} {{route}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "rps" }, "overrides": [] }
      },
      {
        "title": "Latency by status class",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "refId": "A",
            "expr": "histogram_quantile(0.95, sum by (le, status_class) (rate(strait_http_request_duration_seconds_bucket[5m])))",
            "legendFormat": "p95 {{status_class}}"
          },
          {
            "refId": "B",
            "expr": "histogram_quantile(0.99, sum by (le, status_class) (rate(strait_http_request_duration_seconds_bucket[5m])))",
            "legendFormat": "p99 {{status_class}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
      },
      {
        "title": "Inflight requests",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
        "targets": [
          {
            "refId": "A",
            "expr": "sum by (method, route) (strait_http_inflight_requests)",
            "legendFormat": "{{method}} {{route}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
      },
      {
        "title": "Error-class request rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
        "targets": [
          {
            "refId": "A",
            "expr": "sum by (route, status_class) (rate(strait_http_request_duration_seconds_count{status_class=~\"4xx|5xx\"}[5m]))",
            "legendFormat": "{{status_class}} {{route}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "rps" }, "overrides": [] }
      },
      {
        "title": "Slowest routes",
        "type": "table",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
        "targets": [
          {
            "refId": "A",
            "expr": "topk(10, histogram_quantile(0.95, sum by (le, route) (rate(strait_http_request_duration_seconds_bucket[5m]))))",
            "legendFormat": "{{route}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
      }
    ]
  }
}
