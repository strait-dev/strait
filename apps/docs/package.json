{
  "name": "@strait/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "bun run generate:openapi && next build",
    "generate:openapi": "tsx scripts/generate-openapi.mts",
    "postbuild": "bun run generate:llms",
    "generate:llms": "tsx scripts/generate-llms-txt.mts",
    "biome:lint": "biome lint ./app ./lib ./scripts",
    "biome:format": "biome format --write ./app ./lib ./scripts",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@next/third-parties": "^16.1.7",
    "@strait/ui": "workspace:*",
    "fumadocs-core": "^16.6.17",
    "fumadocs-mdx": "^14.2.10",
    "fumadocs-openapi": "^10.3.18",
    "fumadocs-ui": "^16.6.17",
    "geist": "^1.7.0",
    "next": "^16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260318.1",
    "babel-plugin-react-compiler": "^19.1.0-rc.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.20.3",
    "yaml": "^2.8.0",
    "typescript": "^5.9.3"
  }
}
