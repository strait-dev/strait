{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Strait",
  "theme": "luma",
  "colors": {
    "primary": "#FF4F00",
    "light": "#FF4F00",
    "dark": "#FF4F00"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg",
    "href": "https://strait.dev"
  },
  "metadata": {
    "og:site_name": "Strait Docs",
    "og:image": "/images/og.png",
    "og:description": "Documentation for Strait, the open-source job orchestration platform for background jobs and workflows.",
    "og:type": "website",
    "og:locale": "en_US",
    "twitter:card": "summary_large_image",
    "twitter:site": "@leonardomso",
    "twitter:image": "/images/og.png",
    "robots": "index, follow"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "choose-your-path",
              "quickstart",
              "architecture",
              "changelog"
            ]
          },
          {
            "group": "Tutorials",
            "pages": [
              "tutorials/webhook-processor",
              "tutorials/data-pipeline",
              "tutorials/ai-agent"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/jobs",
              "concepts/runs",
              "concepts/workflows",
              "concepts/retry-strategies",
              "concepts/event-triggers",
              "concepts/scheduling",
              "concepts/projects"
            ]
          },
          {
            "group": "Advanced Workflows",
            "pages": [
              "concepts/durable-workflows",
              "concepts/compensating-transactions",
              "concepts/workflow-simulator",
              "concepts/workflow-test-suites",
              "concepts/workflow-debugger"
            ]
          },
          {
            "group": "Reliability",
            "pages": [
              "concepts/resilience",
              "concepts/adaptive-concurrency",
              "concepts/canary-deployments",
              "concepts/cost-budgets",
              "concepts/slos"
            ]
          },
          {
            "group": "Job Features",
            "pages": [
              "concepts/execution-modes",
              "concepts/batch-operations",
              "concepts/job-chaining",
              "concepts/versioning",
              "concepts/environments"
            ]
          },
          {
            "group": "Monitoring",
            "pages": [
              "concepts/real-time",
              "concepts/audit-logging",
              "concepts/log-drains",
              "concepts/webhooks",
              "concepts/webhook-subscriptions",
              "concepts/event-sources",
              "concepts/clickhouse-analytics",
              "concepts/notifications",
              "concepts/debug-bundles"
            ]
          },
          {
            "group": "Configuration",
            "pages": ["configuration/environment-variables"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/authentication",
              "guides/deployment",
              "guides/security",
              "guides/sdk-integration",
              "guides/rbac",
              "guides/idempotency",
              "guides/workflow-approvals",
              "guides/event-triggers",
              "guides/audit-events"
            ]
          },
          {
            "group": "Integrations",
            "pages": ["integrations/index"]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "SDK Reference",
            "pages": [
              "sdks/overview",
              "sdks/configuration",
              "sdks/typescript",
              "sdks/python",
              "sdks/go",
              "sdks/ruby",
              "sdks/rust",
              "sdks/mcp"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/overview"]
          },
          {
            "group": "Endpoints",
            "openapi": "https://api.strait.dev/reference/openapi.json"
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "CLI Reference",
            "pages": ["cli/overview", "cli/api-keys"]
          }
        ]
      },
      {
        "tab": "Billing",
        "groups": [
          {
            "group": "Billing",
            "pages": ["billing/pricing", "billing/faq"]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://strait.dev"
      },
      {
        "label": "Dashboard",
        "href": "https://app.strait.dev"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/strait-dev/strait",
      "x": "https://twitter.com/leonardomso",
      "linkedin": "https://linkedin.com/company/strait"
    }
  },
  "api": {
    "baseUrl": "https://api.strait.dev",
    "playground": {
      "mode": "simple"
    }
  },
  "openapi": "https://api.strait.dev/reference/openapi.json",
  "search": {
    "enabled": true
  },
  "appearance": {
    "default": "dark"
  },
  "feedback": {
    "thumbsRating": true
  },
  "seo": {
    "indexHiddenPages": false
  },
  "redirects": [
    {
      "source": "/docs/getting-started",
      "destination": "/introduction"
    },
    {
      "source": "/docs/getting-started/:slug",
      "destination": "/:slug"
    },
    {
      "source": "/docs/concepts/:slug",
      "destination": "/concepts/:slug"
    },
    {
      "source": "/docs/guides/:slug",
      "destination": "/guides/:slug"
    },
    {
      "source": "/docs/sdks/:slug",
      "destination": "/sdks/:slug"
    },
    {
      "source": "/docs/api-reference/:slug",
      "destination": "/api-reference/:slug"
    },
    {
      "source": "/docs/cli/:slug",
      "destination": "/cli/:slug"
    },
    {
      "source": "/configuration/:slug",
      "destination": "/configuration/:slug"
    }
  ]
}
