{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Strait",
  "theme": "quill",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1E40AF"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg",
    "href": "https://strait.dev"
  },
  "metadata": {
    "og:site_name": "Strait Docs",
    "og:image": "/images/og.png",
    "og:description": "Documentation for Strait, the open-source job orchestration platform for background jobs, workflows, and AI agents.",
    "og:type": "website",
    "og:locale": "en_US",
    "twitter:card": "summary_large_image",
    "twitter:site": "@leonardomso",
    "twitter:image": "/images/og.png",
    "robots": "index, follow"
  },
