# Root .dockerignore for monorepo Docker builds.
# Used when building the TanStack Start app (context = repo root).

.git
.github
.agents
.goreleaser.yaml
.changeset

# Go service test artifacts.
apps/strait/test
apps/strait/internal/loadtest

# Docs and website source (keep package.json for lockfile).
apps/docs/app
apps/docs/lib
apps/docs/scripts
apps/docs/public
apps/website/src
apps/website/public

# Build artifacts and logs.
**/node_modules
**/.turbo
**/.output
**/dist
**/coverage
*.log

# Ops, monitoring, scripts, deploy configs.
packages/monitoring
packages/scripts
packages/deploy
