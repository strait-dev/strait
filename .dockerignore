# Root .dockerignore for monorepo Docker builds.
# Used when building the TanStack Start app (context = repo root).

.git
.github
.agents
.context
.deepsec
.goreleaser.yaml
.changeset

# Local secrets and credentials.
.env
.env.*
!.env.example
.dev.vars
.dev.vars.*
.infisical.json
.sentryclirc
*.pem
*.key
*.p8
*.p12
*.crt

# Go service test artifacts.
apps/strait/test
apps/strait/internal/loadtest

# Docs and website source (keep package.json for lockfile).
apps/docs/app
apps/docs/lib
apps/docs/scripts
apps/docs/public
apps/website/src
apps/website/public

# Build artifacts and logs.
**/node_modules
**/.turbo
**/.output
**/dist
**/coverage
*.log

# Ops, monitoring, scripts configs.
packages/monitoring
packages/scripts
