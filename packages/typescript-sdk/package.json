{
  "name": "@strait/ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf .turbo node_modules dist",
    "biome:lint": "biome lint src test scripts",
    "biome:format": "biome format --write src test scripts",
    "biome:write": "biome check --write src test scripts",
    "biome:fix:unsafe": "biome check --fix --unsafe src test scripts",
    "lint": "bun run biome:lint",
    "typecheck": "tsgo --noEmit",
    "build": "tsgo -p tsconfig.json",
    "test": "bun test",
    "generate:contracts": "bun run ./scripts/generate-contracts.ts",
    "run-all": "bun run biome:format && bun run biome:write && bun run biome:fix:unsafe && bun run biome:lint && bun run typecheck"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260314.1"
  },
  "dependencies": {
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "effect": "^3.19.19",
    "yaml": "^2.8.2"
  }
}
