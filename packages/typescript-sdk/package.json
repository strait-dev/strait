{
  "name": "@strait/ts",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf .turbo node_modules dist",
    "biome:lint": "biome lint src test scripts",
    "biome:format": "biome format --write src test scripts",
    "biome:write": "biome check --write src test scripts",
    "biome:fix:unsafe": "biome check --fix --unsafe src test scripts",
    "lint": "bun run biome:lint",
    "typecheck": "tsgo --noEmit",
    "build": "tsgo -p tsconfig.json",
    "test": "bun test",
    "generate:contracts": "bun run ./scripts/generate-contracts.ts",
    "run-all": "bun run biome:format && bun run biome:write && bun run biome:fix:unsafe && bun run biome:lint && bun run typecheck"
  },
  "exports": {
    ".": "./src/index.ts",
    "./node": "./src/node/index.ts",
    "./fsm": "./src/fsm/index.ts",
    "./ai": "./src/ai/index.ts"
  },
  "peerDependencies": {
    "ai": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "ai": ">=6.0.116"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@standard-schema/spec": "^1.1.0",
    "effect": "^3.21.0",
    "xstate": "5",
    "yaml": "^2.8.2"
  }
}
