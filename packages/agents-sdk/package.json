{
  "name": "@strait/agents",
  "version": "1.0.0",
  "description": "Runtime-side TypeScript SDK for managed Strait agents, provider adapters, budgets, workflow helpers, and run-token callbacks.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/strait-dev/strait/tree/master/packages/agents-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/strait-dev/strait.git",
    "directory": "packages/agents-sdk"
  },
  "bugs": {
    "url": "https://github.com/strait-dev/strait/issues"
  },
  "keywords": [
    "agents",
    "ai",
    "anthropic",
    "cloudflare-workers",
    "llm",
    "openai",
    "strait",
    "vercel-ai"
  ],
  "private": false,
  "type": "module",
  "sideEffects": false,
  "files": [
    "README.md",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf .turbo coverage node_modules",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "biome:lint": "biome lint .",
    "biome:format": "biome format --write .",
    "biome:write": "biome check --write .",
    "biome:fix:unsafe": "biome check --fix --unsafe .",
    "typecheck": "tsgo --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./ai-sdk": "./src/vercel-ai.ts",
    "./agent": "./src/agent.ts",
    "./ai-step": "./src/ai-step.ts",
    "./anthropic": "./src/anthropic.ts",
    "./budget": "./src/budget.ts",
    "./context": "./src/context.ts",
    "./evals": "./src/evals.ts",
    "./errors": "./src/errors.ts",
    "./openai": "./src/openai.ts",
    "./pricing": "./src/pricing.ts",
    "./sandbox": "./src/sandbox.ts",
    "./templates": "./src/templates.ts",
    "./types": "./src/types.ts",
    "./vercel-ai": "./src/vercel-ai.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260409.1",
    "ai": "^6.0.146",
    "fast-check": "^4.6.0",
    "openai": "^6.33.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.80.0",
    "ai": ">=6.0.0",
    "openai": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "dependencies": {
    "effect": "3.21.0"
  }
}
