    "./types": "./src/types.ts",
    "./vercel-ai": "./src/vercel-ai.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260327.2",
