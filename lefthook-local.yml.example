# lefthook-local.yml — per-machine override template
#
# Copy to `lefthook-local.yml` (which is gitignored by lefthook convention)
# and tune for your own box. Local overrides merge on top of `lefthook.yml`
# so you can flip flags without touching the shared config.
#
# Reference: https://lefthook.dev/configuration/remotes/#configuration-priority

# --- Serialize pre-commit on CPU-constrained machines -----------------------
# If your box thrashes under parallel jobs, run them sequentially instead.
pre-commit:
  parallel: false

# --- Opt out of the heavy pre-push piped group ------------------------------
# Useful when you know the next push only touches docs or config.
# pre-push:
#   jobs:
#     - name: thorough
#       skip: true

# --- Raise timeouts on slow laptops -----------------------------------------
# pre-push:
#   jobs:
#     - name: thorough
#       group:
#         jobs:
#           - name: go_lint_fast
#             timeout: 600s
