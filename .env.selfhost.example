# Copy to .env.selfhost or run ./packages/scripts/selfhost-init.sh to generate
# strong random values for all secrets. Do not commit a real .env.selfhost file.

# Required Strait secrets
INTERNAL_SECRET=replace-with-output-of-openssl-rand-hex-32
JWT_SIGNING_KEY=replace-with-output-of-openssl-rand-hex-32
ENCRYPTION_KEY=replace-with-output-of-openssl-rand-base64-32
SECRET_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-base64-32

# Dashboard (Better Auth)
BETTER_AUTH_SECRET=replace-with-output-of-openssl-rand-hex-32

# Sequin
SEQUIN_SECRET_KEY_BASE=replace-with-output-of-two-openssl-rand-hex-32-values
SEQUIN_VAULT_KEY=replace-with-output-of-openssl-rand-base64-32
SEQUIN_API_TOKEN=replace-with-output-of-openssl-rand-hex-32

# Runtime sizing. Keep DB_MAX_CONNS >= WORKER_CONCURRENCY.
WORKER_CONCURRENCY=25
DB_MAX_CONNS=50
DB_MIN_CONNS=10
REDIS_POOL_SIZE=30
REDIS_MIN_IDLE_CONNS=5

# Images. Leave unset to use the release pinned in docker-compose.selfhost.yml.
# STRAIT_IMAGE=ghcr.io/strait-dev/strait:0.1.6
# STRAIT_APP_IMAGE=ghcr.io/strait-dev/strait-app:0.1.6
