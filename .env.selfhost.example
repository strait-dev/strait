# Strait Self-Hosted Environment Variables
#
# This file shows the structure generated by `make selfhost` (via selfhost-init.sh).
# You do NOT need to create this file manually -- the init script generates random
# secrets and writes them to .env.selfhost automatically.
#
# To regenerate all secrets: make selfhost-reset
# To start the stack:        make selfhost

# ---------------------------------------------------------------------------
# Strait API secrets
# ---------------------------------------------------------------------------

# Internal service-to-service authentication token (64-char hex).
INTERNAL_SECRET=

# JWT signing key for SDK tokens and SSE connections (64-char hex).
JWT_SIGNING_KEY=

# AES-256 key for encrypting secrets at rest (44-char base64).
ENCRYPTION_KEY=

# Secondary encryption key for secret rotation (44-char base64).
SECRET_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Dashboard (Better Auth) secrets
# ---------------------------------------------------------------------------

# Encryption key for dashboard session tokens (64-char hex).
BETTER_AUTH_SECRET=

# ---------------------------------------------------------------------------
# Sequin (CDC engine) secrets
# ---------------------------------------------------------------------------

# Phoenix/Erlang secret key base for Sequin (128-char hex).
SEQUIN_SECRET_KEY_BASE=

# Vault encryption key for Sequin's credential store (44-char base64).
SEQUIN_VAULT_KEY=

# ---------------------------------------------------------------------------
# Optional overrides (uncomment to customize)
# ---------------------------------------------------------------------------

# STRAIT_IMAGE=ghcr.io/strait-dev/strait:v1.2.3
# STRAIT_APP_IMAGE=ghcr.io/strait-dev/strait-app:v1.2.3
